# ==========================================
# ASP.NET WebForms / Visual Studio .gitignore
# Safe for OLD ASP.NET (.aspx) Projects
# ==========================================

# ==========================================
# Visual Studio Temporary Files
# ==========================================
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.rsuser
*.cache
*.bak
*.tmp
*.log
*.tlog
*.pidb
*.svclog

# ==========================================
# Build Folders
# ==========================================
obj/
Debug/
Release/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/

# IMPORTANT:
# bin folder ignore mat karo
# old ASP.NET WebForms projects often need DLLs

#bin/

# ==========================================
# IIS Express
# ==========================================
/.vs/config/applicationhost.config

# ==========================================
# Visual Studio Generated Files
# ==========================================
Generated\ Files/
Generated_Code/

# ==========================================
# Test Results
# ==========================================
TestResults/
[Tt]est[Rr]esult*/
*.trx
*.coverage
*.coveragexml

# ==========================================
# SQL Server Files
# ==========================================
*.mdf
*.ldf
*.ndf

# ==========================================
# Publish Files
# ==========================================
publish/
*.publishxml
*.pubxml
*.publishproj

# ==========================================
# NuGet Packages
# ==========================================

# IMPORTANT:
# packages folder ignore mat karo
# old ASP.NET projects need packages/DLLs

#packages/

*.nupkg
*.snupkg

# ==========================================
# Node Modules
# ==========================================
node_modules/

# ==========================================
# ReSharper
# ==========================================
_ReSharper*/
*.DotSettings.user

# ==========================================
# OS Files
# ==========================================
Thumbs.db
Desktop.ini

# ==========================================
# Logs
# ==========================================
*.err
*.out

# ==========================================
# Optional Cache Files
# ==========================================
*.VC.db
*.VC.opendb
*.opendb
*.sdf

# ==========================================
# Python Cache
# ==========================================
__pycache__/
*.pyc

# ==========================================
# Keep Important Source Files
# ==========================================
!*.cs
!*.vb
!*.aspx
!*.ascx
!*.master
!*.asmx
!*.ashx
!*.config
!*.csproj
!*.vbproj
!*.sln
!packages.config
!Web.config
!web.config
!*.sql
!*.js
!*.css
!*.html
!*.json
!*.xml
!*.resx

# ==========================================
# Keep Assets
# ==========================================
!assets/
!Scripts/
!Content/
!bootstrap/
!dist/

# ==========================================
# Optional Ignore
# ==========================================
*.pdb
*.obj
*.ilk
*.meta
*.pch
*.ipdb
*.iobj

# ==========================================
# Local History
# ==========================================
.localhistory/

# ==========================================
# Misc
# ==========================================
mono_crash.*
*.dbmdl
*.jfm
*.pfx
*.publishsettings
orleans.codegen.cs