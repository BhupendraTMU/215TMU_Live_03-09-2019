                          <TextRuns>
                            <TextRun>
                              <Value>=sum(Iif(Fields!CourseCollege.Value &lt;&gt; Fields!UserCollege.Value, Fields!Lecture.Value, 0))+sum(Iif(Fields!CourseCollege.Value &lt;&gt; Fields!UserCollege.Value, Fields!Tutorial.Value, 0))+sum(Iif(Fields!CourseCollege.Value &lt;&gt; Fields!UserCollege.Value, Fields!Practical.Value, 0))</Value>
