  <Code>Public Sno AS Decimal
Public Function GetSno(ByVal GroupName As String) As String
   Dim strBuilder As New System.Text.StringBuilder(GroupName )
   If GroupName .Contains("FacultyCode") Then
      Sno = Sno +1
      Return Sno       
   Else 
      Return ""
   End If
End Function
</Code>
