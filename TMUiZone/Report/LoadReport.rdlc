                      <Paragraphs>
                        <Paragraph>
                          <TextRuns>
                            <TextRun>
                              <Value>=(Sum(Fields!Lecture.Value) + (Sum(Fields!Tutorial.Value) + Sum(Fields!Practical.Value)) / 2)/(Runningvalue(Fields!FacultyCode.Value,CountDistinct,nothing))</Value>
                              <Style>
                                <FontWeight>Bold</FontWeight>
                                <Format>n1</Format>
                              </Style>
                            </TextRun>
                          </TextRuns>
                          <Style>
                            <TextAlign>Center</TextAlign>
                          </Style>
                        </Paragraph>
                      </Paragraphs>
                      <rd:DefaultName>Textbox210</rd:DefaultName>
                      <Style>
