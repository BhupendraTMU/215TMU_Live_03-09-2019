                                                      <FontWeight>Bold</FontWeight>
                                                    </Style>
                                                  </TextRun>
                                                  <TextRun>
                                                    <Value xml:space="preserve"> </Value>
                                                    <Style>
                                                      <FontFamily>Century Schoolbook</FontFamily>
                                                      <FontWeight>Normal</FontWeight>
                                                    </Style>
                                                  </TextRun>
                                                </TextRuns>
                                                <Style />
                                              </Paragraph>
                                              <Paragraph>
                                                <TextRuns>
                                                  <TextRun>
                                                    <Value>1) This is a computer generated grade sheet, does not require any physical signature.</Value>
                                                    <Style>
                                                      <FontFamily>Century Schoolbook</FontFamily>
                                                      <FontWeight>Normal</FontWeight>
                                                    </Style>
                                                  </TextRun>
                                                </TextRuns>
                                                <Style />
                                              </Paragraph>
                                              <Paragraph>
                                                <TextRuns>
                                                  <TextRun>
                                                    <Value>2) Grade sheet issued by office of the Controller of Examinations shall be final.</Value>
                                                    <Style>
