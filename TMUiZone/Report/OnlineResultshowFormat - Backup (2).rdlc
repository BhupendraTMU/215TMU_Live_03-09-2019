                                            <Paragraphs>
                                              <Paragraph>
                                                <TextRuns>
                                                  <TextRun>
                                                    <Value>Passing marks - </Value>
                                                    <Style>
                                                      <FontFamily>Century Schoolbook</FontFamily>
                                                      <FontWeight>Bold</FontWeight>
                                                    </Style>
                                                  </TextRun>
                                                  <TextRun>
                                                    <Value>=Fields!MaxPass.Value</Value>
                                                    <Style>
                                                      <FontFamily>Century Schoolbook</FontFamily>
                                                      <FontWeight>Bold</FontWeight>
                                                    </Style>
                                                  </TextRun>
                                                  <TextRun>
                                                    <Value>% in each course </Value>
                                                    <Style>
                                                      <FontFamily>Century Schoolbook</FontFamily>
                                                      <FontWeight>Bold</FontWeight>
                                                    </Style>
                                                  </TextRun>
                                                  <TextRun>
                                                    <Value>=IIF(Fields!MinMarkRemark.Value&lt;&gt;"","but in " &amp; Fields!MinMarkRemark.Value &amp; " it is " &amp; Fields!Minpass.Value &amp; "%.","")</Value>
                                                    <Style>
                                                      <FontFamily>Century Schoolbook</FontFamily>
                                                      <FontWeight>Bold</FontWeight>
                                                    </Style>
                                                  </TextRun>
                                                </TextRuns>
                                                <Style />
