  <script language="javascript" type="text/javascript">
      function confirmation() {
          var answer = confirm("Are You Sure?\n You Want to Delete Receipt.")
          if (answer) {
              return true;
          }
          else {
              return false;
          }
      }

      function HideProfession() {
          window.document.getElementById("ctl00_ContentPlaceHolder1_trOrg").style.display = "none";
          window.document.getElementById("ctl00_ContentPlaceHolder1_trDesignation").style.display = "none";

          window.document.getElementById("ctl00_ContentPlaceHolder1_trUniversity").style.display = "none";
          window.document.getElementById("ctl00_ContentPlaceHolder1_trProgram").style.display = "none";
      }

      function ShowProfession() {
          window.document.getElementById("ctl00_ContentPlaceHolder1_trOrg").style.display = "block";
          window.document.getElementById("ctl00_ContentPlaceHolder1_trDesignation").style.display = "block";

          window.document.getElementById("ctl00_ContentPlaceHolder1_trUniversity").style.display = "none";
          window.document.getElementById("ctl00_ContentPlaceHolder1_trProgram").style.display = "none";
      }

      function ShowStudying() {
          HideProfession();

          window.document.getElementById("ctl00_ContentPlaceHolder1_trUniversity").style.display = "block";
          window.document.getElementById("ctl00_ContentPlaceHolder1_trProgram").style.display = "block";
      }

      function ShowForIndia() {
          window.document.getElementById("ctl00_ContentPlaceHolder1_trCountry").style.display = "none";
          window.document.getElementById("ctl00_ContentPlaceHolder1_trState").style.display = "block";

          //window.document.getElementById("ctl00_ContentPlaceHolder1_divCountry").style.display = "none";
          //window.document.getElementById("ctl00_ContentPlaceHolder1_divState").style.display = "block";
      }

      function ShowForAbroad() {
          window.document.getElementById("ctl00_ContentPlaceHolder1_trCountry").style.display = "block";
          window.document.getElementById("ctl00_ContentPlaceHolder1_trState").style.display = "none";

          //window.document.getElementById("ctl00_ContentPlaceHolder1_divCountry").style.display = "block";
          //window.document.getElementById("ctl00_ContentPlaceHolder1_divState").style.display = "none";
      }

      function setVisibility() {
          if (window.document.getElementById("ctl00_ContentPlaceHolder1_hdn").value == "1") {
              if (window.document.getElementById("ctl00_ContentPlaceHolder1_rbtHomemaker").checked == true) {
                  HideProfession();
              }

              if (window.document.getElementById("ctl00_ContentPlaceHolder1_rbtIndia").checked == true) {
                  ShowForIndia();
              }

              if (window.document.getElementById("ctl00_ContentPlaceHolder1_rbtAbroad").checked == true) {
                  ShowForAbroad();
              }

              if (window.document.getElementById("ctl00_ContentPlaceHolder1_rbtStudy").checked == true) {
                  ShowStudying();
              }
          }
      }


      function validate() {

          Page_ClientValidate();
          var flag = true;


          if (window.document.getElementById("ctl00_ContentPlaceHolder1_rbtWorking").checked == false && window.document.getElementById("ctl00_ContentPlaceHolder1_rbtBusiness").checked == false && window.document.getElementById("ctl00_ContentPlaceHolder1_rbtHomemaker").checked == false && window.document.getElementById("ctl00_ContentPlaceHolder1_rbtStudy").checked == false) {
              flag = false;
              window.document.getElementById("spProfession").style.display = "block";
          }
          else {
              window.document.getElementById("spProfession").style.display = "none";
          }



          if (window.document.getElementById("ctl00_ContentPlaceHolder1_rbtIndia").checked == false && window.document.getElementById("ctl00_ContentPlaceHolder1_rbtAbroad").checked == false) {
              flag = false;
              window.document.getElementById("spRAdd").style.display = "block";
          }
          else {
              window.document.getElementById("spRAdd").style.display = "none";
          }

          if (window.document.getElementById("ctl00_ContentPlaceHolder1_rbtHomemaker").checked == true) {
              window.document.getElementById("ctl00_ContentPlaceHolder1_spOrg").style.display = "none";
              window.document.getElementById("ctl00_ContentPlaceHolder1_spDesig").style.display = "none";

              flag = true;
          }

          if (window.document.getElementById("ctl00_ContentPlaceHolder1_rbtWorking").checked == true || window.document.getElementById("ctl00_ContentPlaceHolder1_rbtBusiness").checked == true) {

              if (window.document.getElementById("ctl00_ContentPlaceHolder1_txtOrg").value == "") {
                  window.document.getElementById("ctl00_ContentPlaceHolder1_spOrg").style.display = "block";
                  flag = false;
              }
              else {
                  window.document.getElementById("ctl00_ContentPlaceHolder1_spOrg").style.display = "none";
              }

              if (window.document.getElementById("ctl00_ContentPlaceHolder1_txtDesig").value == "") {
                  window.document.getElementById("ctl00_ContentPlaceHolder1_spDesig").style.display = "block";
                  flag = false;
              }
              else {
                  window.document.getElementById("ctl00_ContentPlaceHolder1_spDesig").style.display = "none";
              }

          }

          if (window.document.getElementById("ctl00_ContentPlaceHolder1_rbtStudy").checked == true) {

              if (window.document.getElementById("ctl00_ContentPlaceHolder1_txtUniv").value == "") {
                  window.document.getElementById("ctl00_ContentPlaceHolder1_spUniv").style.display = "block";
                  flag = false;
              }
              else {
                  window.document.getElementById("ctl00_ContentPlaceHolder1_spUniv").style.display = "none";
              }

              if (window.document.getElementById("ctl00_ContentPlaceHolder1_txtProg").value == "") {
                  window.document.getElementById("ctl00_ContentPlaceHolder1_spProg").style.display = "block";
                  flag = false;
              }
              else {
                  window.document.getElementById("ctl00_ContentPlaceHolder1_spProg").style.display = "none";
              }
          }
          //--------------------------------------------------------------------
          if (window.document.getElementById("ctl00_ContentPlaceHolder1_rdoYesC").checked == false && window.document.getElementById("ctl00_ContentPlaceHolder1_rdoNoC").checked == false) {
              flag = false;
              window.document.getElementById("spConfirmC").style.display = "block";
          }
          else {
              window.document.getElementById("spConfirmC").style.display = "none";
          }

          //-----------------------------------------------------------------
          if (window.document.getElementById("ctl00_ContentPlaceHolder1_rdoNoC").checked == true) {
              if (window.document.getElementById("ctl00_ContentPlaceHolder1_rdoNo1").checked == false & window.document.getElementById("ctl00_ContentPlaceHolder1_rdoNo2").checked == false) {
                  window.document.getElementById("spCon1firmNo").style.display = "block";
                  flag = false;
              }
              else {
                  window.document.getElementById("spCon1firmNo").style.display = "none";
              }

          }
          //---------------------------------------------------------------
          if (window.document.getElementById("ctl00_ContentPlaceHolder1_txtguest1").value != "") {


              if (window.document.getElementById("ctl00_ContentPlaceHolder1_ddlG1").value == "0") {
                  window.document.getElementById("ctl00_ContentPlaceHolder1_spGO1").style.display = "block";

                  flag = false;
              }
              else {
                  window.document.getElementById("ctl00_ContentPlaceHolder1_spGO1").style.display = "none";
              }

              if (window.document.getElementById("ctl00_ContentPlaceHolder1_txtOccupation1").value == "") {
                  window.document.getElementById("ctl00_ContentPlaceHolder1_spGO1").style.display = "block";

                  flag = false;
              }
              else {
                  window.document.getElementById("ctl00_ContentPlaceHolder1_spGO1").style.display = "none";
              }
          }

          if (window.document.getElementById("ctl00_ContentPlaceHolder1_txtguest2").value != "") {
              if (window.document.getElementById("ctl00_ContentPlaceHolder1_ddlG2").value == "0") {
                  window.document.getElementById("ctl00_ContentPlaceHolder1_spGO2").style.display = "block";

                  flag = false;
              }
              else {
                  window.document.getElementById("ctl00_ContentPlaceHolder1_spGO2").style.display = "none";
              }

              if (window.document.getElementById("ctl00_ContentPlaceHolder1_txtOccupation2").value == "") {
                  window.document.getElementById("ctl00_ContentPlaceHolder1_spGO2").style.display = "block";

                  flag = false;
              }
              else {
                  window.document.getElementById("ctl00_ContentPlaceHolder1_spGO2").style.display = "none";
              }


          }
          //------------------------------------------------------------------------
          //return flag;

          if (flag == true) {
              var answer = confirm("Are You Sure?\n You Want to Submit.")
              if (answer) {
                  return true;
              }
              else {
                  return false;
              }
          }
          else {
              return flag;
          }

      }
		</script>
		
