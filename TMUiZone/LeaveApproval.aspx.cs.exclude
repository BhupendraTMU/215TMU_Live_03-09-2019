                    con.DisConnect();
                }
                else
                {
                    SqlDataReader odr = con.Leave_Approval_rejected_withUserNameAllReject(Session["uid"].ToString(), Session["Company"].ToString());
                    DataTable Dt = new DataTable();
                    Dt.Load(odr);
                    grdRejected.DataSource = Dt;
                    grdRejected.DataBind();
                    odr.Close();
                    con.DisConnect();
                }
            }



        }


    }


