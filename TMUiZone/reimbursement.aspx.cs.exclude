    public void showCreditLimit()
    {
        string Expense_AmountMax = ""; string Salary_Based = ""; string Salary_Based_Type = ""; txtCreditLimit.Text = "";
        SqlDataReader dr = con.Show_Reimburs_creditlimitINDV(Session["Company"].ToString(), ddExpenseType.SelectedValue.ToString(),Session["uid"].ToString());
        dr.Read();
        if (dr.HasRows)
        {
            Salary_Based = dr["Salary_Based"].ToString();
            Salary_Based_Type = dr["Salary_Based_Type"].ToString();
            if (Salary_Based == "Yes")
            {
                if (Salary_Based_Type == "Basic Salary")
                {


                }
                if (Salary_Based_Type == "Gross Salary")
                {


                }
                if (Salary_Based_Type == "Fixed Amount")
                {

                    txtCreditLimit.Text = dr["Expense_AmountMax"].ToString();
                }
            }
            else
            {
                txtCreditLimit.Text = dr["Expense_AmountMax"].ToString();
            }
            dr.Close();
            con.DisConnect();
        }
        else
        {
            dr.Close();
            con.DisConnect();
            showCreditLimitAll();
        }
       
    }


 


