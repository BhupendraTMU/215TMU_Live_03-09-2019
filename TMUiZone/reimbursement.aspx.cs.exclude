    protected void Page_Load(object sender, EventArgs e)
    {
        try
        {
            Portalcon = new Connection();
            con = new ServicePoratal();
            Showpermission();
            if (!IsPostBack)
            {
                ShowExpensiveType();
            }
        }
        catch (Exception)
        {
            Response.Redirect("Default.aspx");
        }
    }


    public void ShowExpensiveType()
    {
        string startdate = ""; string endDate = "";
        SqlDataReader dr = con.Show_Reimbursmenttypewithfilldataindv(Session["Company"].ToString(), Session["uid"].ToString());
        dr.Read();
        if (dr.HasRows)
        {
            


            startdate = dr["Start_Date"].ToString();
            endDate = dr["End_Date"].ToString();

            dr.Close();
            con.DisConnect();
            string curdatetime = System.DateTime.Now.ToString("yyyy-MM-dd");
            DateTime statartdate1 = DateTime.ParseExact(startdate.Trim(), "yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture);
            DateTime enddate1 = DateTime.ParseExact(curdatetime, "yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture);
            if (statartdate1 > enddate1)
            {



            }
            else
            {
                SqlDataReader drindv = con.Show_Reimbursmenttypewithfilldataindv(Session["Company"].ToString(), Session["uid"].ToString());
                
                ddExpenseType.DataSource = drindv;
                ddExpenseType.DataTextField = "Expense_Type";
                ddExpenseType.DataBind();
                drindv.Close();
                con.DisConnect();
            }
        }

        else
        {
            dr.Close();
            con.DisConnect();
            ShowExpensiveTypeAll();
        }
        
    }


