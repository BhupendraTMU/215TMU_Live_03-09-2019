                if (BandwiseALLremt == "True" && GradewiseALLremt == "True" && DepartmentwiseALLremt == "True" && LocationwiseALLremt == "True")
                {

                    if (Band_Coderemt == Session["BandCodereim"].ToString() && Grade_Coderemt == Session["Gradereim"].ToString() && Department_Coderemt == Session["Departmentcode"].ToString() && Location_Coderemt == Session["LocationCodereim"].ToString())
                    {
                        if (Salary_Based == "Yes")
                        {
                            if (Salary_Based_Type == "Basic Salary")
                            {


                            }
                            if (Salary_Based_Type == "Gross Salary")
                            {


                            }
                            if (Salary_Based_Type == "Fixed Amount")
                            {

                                txtCreditLimit.Text = ds.Tables[0].Rows[i]["Expense_AmountMax"].ToString();
                            }
                        }
                        else
                        {
                            txtCreditLimit.Text = ds.Tables[0].Rows[i]["Expense_AmountMax"].ToString();
                        }
                    }

                }
          //  }
        }
        con.DisConnect();
    
    }

   

    
    string lblslno = "";
    public void lastrec()
    {
        string updatedate = System.DateTime.Now.ToString("yyyy-MM-dd");
        SqlDataReader dr = con.SHow_SerialNo(Session["uid"].ToString(), updatedate, Session["Company"].ToString());

        dr.Read();
        if (dr.HasRows)
        {

            string d = dr["SerialNo"].ToString();
            double rec = Convert.ToInt64(d);
            double c1 = rec + 1;
            lblslno = c1.ToString();
        }

        else
        {
            lblslno = "1";

        }

        dr.Close();
        con.DisConnect();



    }

