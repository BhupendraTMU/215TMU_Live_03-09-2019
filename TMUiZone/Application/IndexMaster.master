                                            <li style="margin-left: 0px" id="VirtualID" runat="server" visible="true"><a href="VirtualIDCard.aspx"><b>Virtual ID Card</b></a> </li>
                                            <li style="margin-left: 0px" id="CourseSelection" runat="server" visible="false"><a href="CourseSelection.aspx"><b>SELECT SPECIALIZATION</b></a> </li>
                                            <li style="margin-left: 0px" id="Li1" runat="server"><a href="ViewAttendance.aspx"><b>View Attendance</b></a> </li>
