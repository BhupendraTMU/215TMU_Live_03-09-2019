            </table>
            <div class="modal fade" id="myModal" role="dialog">
                <div class="modal-dialog">

                    <!-- Modal content-->
                    <div class="modal-content">
                        <div class="modal-header" style="background-color: #88CCFF;">
                            <div>
                                <button type="button" class="close" data-dismiss="modal">&times;</button>
                                <h4 class="modal-title"><b style="font-family: 'SketchFlow Print'; font-size: 15px">Change Password</b></h4>
                            </div>
                        </div>
                        <div class="modal-body">
                            <div class="col-lg-3" style="padding-right: 0px; font-size: 12px;">
                                <asp:Label ID="Label28" Style="line-height: 30px" runat="server" Font-Bold="true" Text="Label"><b>Old Password:</b></asp:Label>
                            </div>
                            <div class="col-lg-8" style="padding-right: 0px;">
                                <div class="form-group">
                                    <div class="input-group">
                                        <span class="input-group-addon"><span class="glyphicon glyphicon-education"></span></span>
                                        <asp:TextBox runat="server" TextMode="Password" ID="txtOldPassword" CssClass="form-control input-sm" Height="30px"></asp:TextBox>
                                    </div>
                                </div>
                                <asp:RequiredFieldValidator ID="RequiredFieldValidator3" runat="server" Display="Dynamic" ForeColor="Red" ErrorMessage="Please input the old password!" ControlToValidate="txtOldPassword" ValidationGroup="g3"></asp:RequiredFieldValidator>
                            </div>
                            <div class="clearfix"></div>
                            <div class="col-lg-3" style="padding-right: 0px; font-size: 12px;">
                                <asp:Label ID="Label2" Style="line-height: 30px" runat="server" Font-Bold="true" Text="Label"><b>New Password:</b></asp:Label>
                            </div>
                            <div class="col-lg-8" style="padding-right: 0px;">
                                <div class="form-group">
                                    <div class="input-group">
                                        <span class="input-group-addon"><span class="glyphicon glyphicon-education"></span></span>
                                        <asp:TextBox runat="server" TextMode="Password" ID="txtNewPassword" CssClass="form-control input-sm" Height="30px"></asp:TextBox>
                                    </div>
                                </div>
                                <asp:RequiredFieldValidator ID="RequiredFieldValidator2" runat="server" Display="Dynamic" ForeColor="Red" ErrorMessage="Please input the new password!" ControlToValidate="txtNewPassword" ValidationGroup="g3"></asp:RequiredFieldValidator>
                            </div>
                            <div class="clearfix"></div>
                            <div class="col-lg-3" style="padding-right: 0px; font-size: 12px;">
                                <asp:Label ID="Label3" Style="line-height: 30px" runat="server" Font-Bold="true" Text="Label"><b>Confirm Password:</b></asp:Label>
                            </div>
                            <div class="col-lg-8" style="padding-right: 0px;">
                                <div class="form-group">
                                    <div class="input-group">
                                        <span class="input-group-addon"><span class="glyphicon glyphicon-education"></span></span>
                                        <asp:TextBox runat="server" TextMode="Password" ID="txtConfirmPassword" CssClass="form-control input-lg" Height="30px"></asp:TextBox>
                                    </div>
                                </div>
                                <asp:RequiredFieldValidator ID="RequiredFieldValidator1" runat="server" Display="Dynamic" ForeColor="Red" ErrorMessage="Please input the confirm password!" ControlToValidate="txtConfirmPassword" ValidationGroup="g3"></asp:RequiredFieldValidator>
                                <asp:CompareValidator ID="CompareValidator1" runat="server" ControlToCompare="txtNewPassword" ControlToValidate="txtConfirmPassword" ErrorMessage="The password does not match!" ValidationGroup="g3"></asp:CompareValidator>
                            </div>
                        </div>
                        <%-- <div class="modal-footer" style="border-top-width:0px">
                  <asp:Button runat="server" ID="btnChangePassword"  CssClass="btn-sm btn-primary" Width="20%" onclick="btnChangePassword_Click"  ValidationGroup="g3" Text="Change"></asp:Button>
                </div>--%>
                    </div>

                </div>
            </div>
        </div>
        <div class="modal fade" id="myModal1" role="dialog">
            <div class="modal-dialog">
                <!-- Modal content-->
                <div class="modal-content">
                    <div class="modal-header" style="background-color: #88CCFF;">
                        <div>
                            <button type="button" class="close" data-dismiss="modal">&times;</button>
                            <h4 class="modal-title"><b style="font-family: 'SketchFlow Print'; font-size: 15px; font-weight: bold">Upload Image  (Min Size 40KB Max Size 50KB )</b></h4>
                        </div>
                    </div>
                    <div class="modal-body">
                        <div class="col-lg-3" style="padding-right: 0px; font-size: 12px;">
                            <asp:Label ID="Label4" Style="line-height: 30px" runat="server" Font-Bold="true" Text="Label"><b>Choose Image:</b></asp:Label>
                        </div>
                        <div class="col-lg-8" style="padding-right: 0px;">
                            <div class="form-group">
                                <asp:FileUpload runat="server" ID="imgUpload" />
                            </div>
                            <asp:RequiredFieldValidator ID="RequiredFieldValidator4" runat="server" Display="Dynamic" ForeColor="Red" ErrorMessage="First choose the file!" ControlToValidate="imgUpload" ValidationGroup="g4"></asp:RequiredFieldValidator>
                        </div>

                    </div>
                    <%--  <div class="modal-footer" style="border-top-width:0px">
                  <asp:Button runat="server" ID="btnChangeImage" OnClientClick = "return ValidateFile()" OnClick="btnChangeImage_Click" CssClass="btn-sm btn-primary" Width="20%"  ValidationGroup="g4" Text="Change Image"></asp:Button>
                </div>--%>
                </div>

            </div>
        </div>
