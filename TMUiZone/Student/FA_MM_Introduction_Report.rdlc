            <TablixRow>
              <Height>2.81944in</Height>
              <TablixCells>
                <TablixCell>
                  <CellContents>
                    <Textbox Name="Textbox117">
                      <CanGrow>true</CanGrow>
                      <KeepTogether>true</KeepTogether>
                      <Paragraphs>
                        <Paragraph>
                          <TextRuns>
                            <TextRun>
                              <Value>A good student mentor is someone who engages in a positive relationship with the student and give</Value>
                              <Style />
                            </TextRun>
                          </TextRuns>
                          <ListStyle>Bulleted</ListStyle>
                          <ListLevel>1</ListLevel>
                          <Style>
                            <TextAlign>Left</TextAlign>
                          </Style>
                        </Paragraph>
                        <Paragraph>
                          <TextRuns>
                            <TextRun>
                              <Value>them attention.</Value>
                              <Style />
                            </TextRun>
                          </TextRuns>
                          <ListLevel>1</ListLevel>
                          <Style>
                            <TextAlign>Left</TextAlign>
                          </Style>
                        </Paragraph>
                        <Paragraph>
                          <TextRuns>
                            <TextRun>
                              <Value />
                              <Style />
                            </TextRun>
                          </TextRuns>
                          <ListLevel>1</ListLevel>
                          <Style>
                            <TextAlign>Left</TextAlign>
                          </Style>
                        </Paragraph>
                        <Paragraph>
                          <TextRuns>
                            <TextRun>
                              <Value>The mentor needs to have positive self-esteem, react well to stressful situations and tolerate frust-</Value>
                              <Style />
                            </TextRun>
                          </TextRuns>
                          <ListStyle>Bulleted</ListStyle>
                          <ListLevel>1</ListLevel>
                          <Style>
                            <TextAlign>Left</TextAlign>
                          </Style>
                        </Paragraph>
                        <Paragraph>
                          <TextRuns>
                            <TextRun>
                              <Value>rating situations.</Value>
                              <Style />
                            </TextRun>
                          </TextRuns>
                          <ListLevel>1</ListLevel>
                          <Style>
                            <TextAlign>Left</TextAlign>
                          </Style>
                        </Paragraph>
                        <Paragraph>
                          <TextRuns>
                            <TextRun>
                              <Value />
                              <Style />
                            </TextRun>
                          </TextRuns>
                          <ListLevel>1</ListLevel>
                          <Style>
                            <TextAlign>Left</TextAlign>
                          </Style>
                        </Paragraph>
                        <Paragraph>
                          <TextRuns>
                            <TextRun>
                              <Value>They need to listen well and communicate on a level that the student can understand and not be</Value>
                              <Style />
                            </TextRun>
                          </TextRuns>
                          <ListStyle>Bulleted</ListStyle>
                          <ListLevel>1</ListLevel>
                          <Style>
                            <TextAlign>Left</TextAlign>
                          </Style>
                        </Paragraph>
                        <Paragraph>
                          <TextRuns>
                            <TextRun>
                              <Value>judgmental.</Value>
                              <Style />
                            </TextRun>
                          </TextRuns>
                          <ListLevel>1</ListLevel>
                          <Style>
                            <TextAlign>Left</TextAlign>
                          </Style>
                        </Paragraph>
                        <Paragraph>
                          <TextRuns>
                            <TextRun>
                              <Value />
                              <Style />
                            </TextRun>
                          </TextRuns>
                          <ListLevel>1</ListLevel>
                          <Style>
                            <TextAlign>Left</TextAlign>
                          </Style>
                        </Paragraph>
                        <Paragraph>
                          <TextRuns>
                            <TextRun>
                              <Value>The mentor needs to provide leadership and guidance and be a positive role model, nurturing a re-</Value>
                              <Style />
                            </TextRun>
                          </TextRuns>
                          <ListStyle>Bulleted</ListStyle>
                          <ListLevel>1</ListLevel>
                          <Style>
                            <TextAlign>Left</TextAlign>
                          </Style>
                        </Paragraph>
                        <Paragraph>
                          <TextRuns>
                            <TextRun>
                              <Value>lationship that respects the student's dignity.</Value>
                              <Style />
                            </TextRun>
                          </TextRuns>
                          <ListLevel>1</ListLevel>
                          <Style>
                            <TextAlign>Left</TextAlign>
                          </Style>
                        </Paragraph>
                        <Paragraph>
                          <TextRuns>
                            <TextRun>
                              <Value />
                              <Style />
                            </TextRun>
                          </TextRuns>
                          <ListLevel>1</ListLevel>
                          <Style>
                            <TextAlign>Left</TextAlign>
                          </Style>
                        </Paragraph>
                        <Paragraph>
                          <TextRuns>
                            <TextRun>
                              <Value>The mentor must always show up on time for sessions, be committed and accept their responsibili-</Value>
                              <Style />
                            </TextRun>
                          </TextRuns>
                          <ListStyle>Bulleted</ListStyle>
                          <ListLevel>1</ListLevel>
                          <Style>
                            <TextAlign>Left</TextAlign>
                          </Style>
                        </Paragraph>
                        <Paragraph>
                          <TextRuns>
                            <TextRun>
                              <Value>ties.</Value>
                              <Style />
                            </TextRun>
                          </TextRuns>
                          <ListLevel>1</ListLevel>
                          <Style>
                            <TextAlign>Left</TextAlign>
                          </Style>
                        </Paragraph>
                        <Paragraph>
                          <TextRuns>
                            <TextRun>
                              <Value />
                              <Style />
                            </TextRun>
                          </TextRuns>
                          <ListLevel>1</ListLevel>
                          <Style>
                            <TextAlign>Left</TextAlign>
                          </Style>
                        </Paragraph>
                        <Paragraph>
                          <TextRuns>
                            <TextRun>
                              <Value>They will not break the trust they have established.</Value>
                              <Style />
                            </TextRun>
                          </TextRuns>
                          <ListStyle>Bulleted</ListStyle>
                          <ListLevel>1</ListLevel>
                          <Style>
                            <TextAlign>Left</TextAlign>
                          </Style>
                        </Paragraph>
                        <Paragraph>
                          <TextRuns>
                            <TextRun>
                              <Value />
                              <Style />
                            </TextRun>
                          </TextRuns>
                          <Style>
                            <TextAlign>Left</TextAlign>
                          </Style>
                        </Paragraph>
                      </Paragraphs>
                      <rd:DefaultName>Textbox117</rd:DefaultName>
                      <Style>
                        <Border>
                          <Style>None</Style>
                        </Border>
                        <PaddingLeft>2pt</PaddingLeft>
                        <PaddingRight>2pt</PaddingRight>
                        <PaddingTop>2pt</PaddingTop>
                        <PaddingBottom>2pt</PaddingBottom>
                      </Style>
                    </Textbox>
                    <ColSpan>16</ColSpan>
