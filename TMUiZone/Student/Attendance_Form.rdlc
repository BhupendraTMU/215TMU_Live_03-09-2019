                      <Paragraphs>
                        <Paragraph>
                          <TextRuns>
                            <TextRun>
                              <Value>I am signing this undertaking after reading the University Ordinance on attendance and other matters.</Value>
                              <Style>
                                <FontWeight>Normal</FontWeight>
                                <TextDecoration>None</TextDecoration>
                              </Style>
                            </TextRun>
