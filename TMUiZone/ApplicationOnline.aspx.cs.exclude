        parameters.Add("CUST_ID", txtAppEnquiryNo.Text.Replace("/", "").ToString());
        parameters.Add("ORDER_ID", orderid);
        parameters.Add("TXN_AMOUNT", lblApplicationCost.Text);
        // parameters.Add("CALLBACK_URL", Path.GetDirectoryName(HttpContext.Current.Request.Url.OriginalString) + "/PaytmTransactionStatus.aspx"); 

        parameters.Add("CALLBACK_URL", "http://localhost:7267/TMUiZone/PaytmTransactionStatus.aspx");
        // parameters.Add("CALLBACK_URL", "http://14.139.238.130:82/PaytmTransactionStatus.aspx");

        string checksum = CheckSum.generateCheckSum(merchantKey, parameters);
        //string paytmURL = "https://pguat.paytm.com/oltp-web/processTransaction?orderid=" + orderid;//Test
        string paytmURL = "https://secure.paytm.in/oltp-web/processTransaction?orderid=" + orderid;//Live

        string outputHTML = "<html>";
        outputHTML += "<head>";
        outputHTML += "<title>Merchant Check Out Page</title>";
        outputHTML += "</head>";
        outputHTML += "<body>";
        outputHTML += "<center><h1>Please do not refresh this page...</h1></center>";
        outputHTML += "<form method='post' action='" + paytmURL + "' name='f1'>";
        outputHTML += "<table border='1'>";
        outputHTML += "<tbody>";
        foreach (string key in parameters.Keys)
        {
            outputHTML += "<input type='hidden' name='" + key + "' value='" + parameters[key] + "'>";
        }
        outputHTML += "<input type='hidden' name='CHECKSUMHASH' value='" + checksum + "'>";
        outputHTML += "</tbody>";
        outputHTML += "</table>";
        outputHTML += "<script type='text/javascript'>";
        outputHTML += "document.f1.submit();";
        outputHTML += "</script>";
        outputHTML += "</form>";
        outputHTML += "</body>";
        outputHTML += "</html>";
        Response.Write(outputHTML);

    }
    public class DdlData
    {
        public string No_ { get; set; }
        public string Details { get; set; }
    }

    [System.Web.Script.Services.ScriptMethod()]
    [System.Web.Services.WebMethod]

    public static List<DdlData> BindDistrict(string StateCode)
    {
        DataTable dt = new DataTable();
        CommonDL objCommonDL = new CommonDL();
        dt = objCommonDL.GetDistrictDdl(StateCode);
        List<DdlData> DistrictData = new List<DdlData>();
        for (int i = 0; i < dt.Rows.Count; i++)
        {
            DistrictData.Add(new DdlData
            {
                No_ = dt.Rows[i]["No_"].ToString(),
                Details = dt.Rows[i]["Details"].ToString(),
            });
        }
        return DistrictData;
    }
    [System.Web.Script.Services.ScriptMethod()]
    [System.Web.Services.WebMethod]
    public static List<DdlData> BindCity(string StateCode,string DistrictCode)
    {
        DataTable dt = new DataTable();
        CommonDL objCommonDL = new CommonDL();
       // dt = objCommonDL.GetDistrictDdl(DistrictCode);
        dt = objCommonDL.GetCityDdl(StateCode,DistrictCode);
        List<DdlData> CityData = new List<DdlData>();
        for (int i = 0; i < dt.Rows.Count; i++)
        {
            CityData.Add(new DdlData
            {
                No_ = dt.Rows[i]["No_"].ToString(),
                Details = dt.Rows[i]["Details"].ToString(),
            });
        }
        return CityData;
    }
    protected void ddlPermState_SelectedIndexChanged(object sender, EventArgs e)
    {
        BindDdlPermDistrict();
    }
    protected void ddlPermDistrict_SelectedIndexChanged(object sender, EventArgs e)
    {
        BindDdlPermCity();
    }

    protected void ddlCorresState_SelectedIndexChanged(object sender, EventArgs e)
    {
        BindDdlCorresDistrict();
    }
    protected void ddlCorresDistrict_SelectedIndexChanged(object sender, EventArgs e)
    {
        BindDdlCorresCity();
    }

    protected void txtMarkObtained_TextChanged(object sender, EventArgs e)
    {
        try
        {
            if (Convert.ToInt32(txtMarkObtained.Text) > (Convert.ToInt32(txtMaximum.Text)))

            {
                ScriptManager.RegisterClientScriptBlock(this, this.GetType(), "alertMessage", "alert('Obtained marks cannot be greater than maximum marks .')", true);
                txtPercentageOfMarks.Text = "";
                return;
                
            }
            else
            {

                SqlCommand cmd = new SqlCommand("sp_getpercentage", con);
                cmd.CommandType = CommandType.StoredProcedure;
                cmd.Parameters.AddWithValue("@Maximum", txtMaximum.Text);
                cmd.Parameters.AddWithValue("@Obtained", txtMarkObtained.Text);
                con.Open();
                SqlDataAdapter da = new SqlDataAdapter(cmd);
                DataTable dt = new DataTable();
                da.Fill(dt);
                con.Close();
                txtPercentageOfMarks.Text = dt.Rows[0]["Percentage"].ToString();
            }
        }
        catch (Exception ex) { }



    }
  
}