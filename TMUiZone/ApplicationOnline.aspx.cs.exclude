    public void PayUmoney()
    {
        if (lblApplicationCost.Text == "") { lblApplicationCost.Text = "0"; }
        if (Convert.ToDouble(lblApplicationCost.Text) <= 0) { lblMsg.Text = "Amount should be greater than 0"; return; }
        else
        {
            Random RNo =new Random();
            TransId = txtAppEnquiryNo.Text +RNo.Next(10000,99999);
            String sDate = DateTime.Now.ToString();
            DateTime datevalue = (Convert.ToDateTime(sDate.ToString()));
            String dy = datevalue.Day.ToString();
            String mn = datevalue.Month.ToString();
            String yy = datevalue.Year.ToString();
            string date1 = mn + "/" + dy + "/" + yy;
            string time1 = System.DateTime.Now.TimeOfDay.ToString();

        }
        // end save record in database
        try
        {
            string[] hashVarsSeq; string hash_string = string.Empty;
            if (string.IsNullOrEmpty(Request.Form["txnid"])) // generating txnid
            {
                Random rnd = new Random();
                string strHash = Generatehash512(rnd.ToString() + DateTime.Now);
                txnid1 = TransId;
            }
            else
            {
                txnid1 = TransId;
            }
            if (string.IsNullOrEmpty(Request.Form["hash"])) // generating hash value
            {
                if (string.IsNullOrEmpty(ConfigurationManager.AppSettings["MERCHANT_KEY"]) || string.IsNullOrEmpty(txnid1) || txtApplicantName.Text == "" || txtEmailAddress.Text == "")
                {
                    lblMsg.Text = "Error on Page";
                    return;
                }
                else
                {
                    lblMsg.Text = "";
                    hashVarsSeq = ConfigurationManager.AppSettings["hashSequence"].Split('|'); // spliting hash sequence from config
                    hash_string = "";
                    foreach (string hash_var in hashVarsSeq)
                    {
                        if (hash_var == "key")
                        {
                            hash_string = hash_string + ConfigurationManager.AppSettings["MERCHANT_KEY"];
                            hash_string = hash_string + '|';
                        }
                        else if (hash_var == "txnid")
                        {
                            hash_string = hash_string + txnid1;
                            hash_string = hash_string + '|';
                        }
                        else if (hash_var == "amount")
                        {                            
                            hash_string = hash_string + Convert.ToDecimal(lblApplicationCost.Text).ToString("g29");
                            hash_string = hash_string + '|';
                        }
                        else if (hash_var == "productinfo")  //new code
                        { 
                            hash_string += "{\"paymentIdentifiers\":" + GetJson().ToString() + "}";
                            hash_string = hash_string + '|';
                        }

                        else
                        {
                            if (hash_var == "firstname")
                            {                                
                                hash_string = hash_string + txtApplicantName.Text;
                                hash_string = hash_string + '|';
                            }
                            else if (hash_var == "email")
                            {                               
                                hash_string = hash_string + txtEmailAddress.Text;
                                hash_string = hash_string + '|';
                            }
                            else
                            {
                                hash_string = hash_string + (Request.Form[hash_var] != null ? Request.Form[hash_var] : "");// isset if else
                                hash_string = hash_string + '|';
                            }

                        }
                    }
                    hash_string += ConfigurationManager.AppSettings["SALT"];
                    hash1 = Generatehash512(hash_string).ToLower();
                    action1 = ConfigurationManager.AppSettings["PAYU_BASE_URL"] + "/_payment";
                }
            }
            else if (!string.IsNullOrEmpty(Request.Form["hash"]))
            {
                hash1 = Request.Form["hash"];
                action1 = ConfigurationManager.AppSettings["PAYU_BASE_URL"] + "/_payment";
            }
            if (!string.IsNullOrEmpty(hash1))
            {
                hash.Value = hash1; txnid.Value = txnid1;
                System.Collections.Hashtable data = new System.Collections.Hashtable(); // adding values in gash table for data post
                data.Add("hash", hash.Value);
                data.Add("txnid", txnid.Value);
                data.Add("key", key.Value);
                string AmountForm = Convert.ToDecimal(lblApplicationCost.Text.Trim()).ToString("g29");// eliminating trailing zeros
                data.Add("amount", AmountForm);
                data.Add("firstname", txtApplicantName.Text);
                data.Add("email", txtEmailAddress.Text);
                data.Add("phone", txtAppMobileNo.Text);
                data.Add("productinfo", HttpUtility.HtmlEncode("{\"paymentIdentifiers\":" + GetJson().ToString() + "}"));  //-->new code gives checksum failed
                data.Add("surl", Path.GetDirectoryName(HttpContext.Current.Request.Url.OriginalString) + "/surl.aspx");
                //---------------Local--------------------
                data.Add("furl", "http://localhost:7248/furl.aspx");      // data.Add("furl", Request.Form["furl"].Trim());//http://tmu.ac.in/feepay/furl.aspx
                data.Add("lastname", "");
                data.Add("curl", "http://localhost:7248/curl.aspx");      // data.Add("curl", Request.Form["curl"].Trim());//http://tmu.ac.in/feepay/curl.aspx
                //---------------Local--------------------
                ////---------------Live--------------------
                //data.Add("furl", "http://172.0.1.105:82/furl.aspx");      // data.Add("furl", Request.Form["furl"].Trim());//http://tmu.ac.in/feepay/furl.aspx
                //data.Add("lastname", "");
                //data.Add("curl", "http://172.0.1.105:82/curl.aspx");      // data.Add("curl", Request.Form["curl"].Trim());//http://tmu.ac.in/feepay/curl.aspx
                //---------------Live--------------------
                data.Add("address1", "");
                data.Add("address2", "");
                data.Add("city", "");
                data.Add("state", "");
                data.Add("country", "");
                data.Add("zipcode", "");
                data.Add("udf1", "");
                data.Add("udf2", "");
                data.Add("udf3", "");
                data.Add("udf4", "");
                data.Add("udf5", "");
                data.Add("pg", "");
                data.Add("service_provider", "payu_paisa");                 //data.Add("service_provider", Request.Form["service_provider"].Trim());//payu_paisa
                string strForm = PreparePOSTForm(action1, data);
                Page.Controls.Add(new LiteralControl(strForm));
            }
            else
            {
                //no hash
            }
        }
        catch (Exception ex)
        {
            lblMsg.Text = ex.Message;

        }

    }
    public string GetJson()
    {
        System.Web.Script.Serialization.JavaScriptSerializer serializer = new System.Web.Script.Serialization.JavaScriptSerializer();
        List<Dictionary<string, object>> rows = new List<Dictionary<string, object>>();
        Dictionary<string, object> row = null;
        DataTable dtEmployee = new DataTable();
        dtEmployee.Columns.Add("field", typeof(string));
        dtEmployee.Columns.Add("value", typeof(string));
        dtEmployee.Rows.Add("StudentName", txtApplicantName.Text);
        dtEmployee.Rows.Add("Fee_Type", FeeType);
        foreach (DataRow dr in dtEmployee.Rows)
        {
            row = new Dictionary<string, object>();
            foreach (DataColumn col in dtEmployee.Columns)
            {
                row.Add(col.ColumnName, dr[col]);
            }
            rows.Add(row);
        }
        return serializer.Serialize(rows);
    }
    
