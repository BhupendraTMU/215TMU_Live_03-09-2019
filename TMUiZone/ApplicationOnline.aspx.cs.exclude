    public void RegistrationSteps()
    {
        lblMsg.Text = "";
        if (rblRegStep.SelectedIndex == 0)
        {
            dvEnquiry.Visible = true;
            dvApplication.Visible = false;
            dvFamily.Visible = false;
            dvAddress.Visible = false;
            dvQualification.Visible = false;
            dvAddress.Visible = false;
        }
        if (rblRegStep.SelectedIndex == 1)
        {
            dvEnquiry.Visible = false;
            dvOTP.Visible = true;
            dvAppDetails.Visible = false;
            dvApplication.Visible = true;
            dvFamily.Visible = false;
            dvAddress.Visible = false;
            dvQualification.Visible = false;
        }
        if (rblRegStep.SelectedIndex == 2)
        {
            dvEnquiry.Visible = false;
            dvApplication.Visible = false;
            dvFamily.Visible = false;
            dvAddress.Visible = false;
            dvQualification.Visible = false;
        }
        if (dvAppDetails.Visible == false)
        {
            btnSave.Visible = false;
        }
        else
        {
            btnSave.Visible = true;
        }

    }
    protected void btnEnqNoGenerate_Click(object sender, EventArgs e)
    {
        lblMsg.Text = "";
        if (txtEnqApplicantName.Text == "" || txtEnqMobileNo.Text == "" || ddlEnqCourse.SelectedIndex == 0)
        {
            lblMsg.Text = "Fill Name/Mobile No/Course..!";
            return;
        }
        string EnquiryNoGen = apdl.SaveAndGenerateEnquiryForApplicant(txtEnqApplicantName.Text, ddlEnqCourse.SelectedValue, txtEnqMobileNo.Text, txtWhatsappNo.Text);

        if (EnquiryNoGen.Length <= 15)
        {
           lblMsg.Text = "Your Enquiry No is :" + EnquiryNoGen + " ";
            //Send Message//
            //string EnqMsg = "Your Enquiry No is :" + EnquiryNoGen + " ";
            SendMessage(txtEnqMobileNo.Text, lblMsg.Text);//Message 

            lblMsg.Text = "Enquiry No has been sent to your Mobile No !";
            //Send Message//
            rblRegStep.SelectedIndex = 1;
            if (rblRegStep.SelectedIndex == 1)
            {
                dvOTP.Visible = true;
                dvEnquiry.Visible = false;
                dvAppDetails.Visible = false;
                dvApplication.Visible = true;
                dvFamily.Visible = false;
                dvAddress.Visible = false;
                dvQualification.Visible = false;
                txtAppEnquiryNo.Text = EnquiryNoGen;
                txtAppMobileNo.Text = txtEnqMobileNo.Text;
            }
        }
        else
        {
            lblMsg.Text = EnquiryNoGen;
        }
    }
    public void SMS(String MobileNo, string Msg)
    {
        //  Website: http://www.universalsmsadvertising.com/     //  Username: 9837016352   //  Password: 9837016352 
        // MobileNo = "91" + MobileNo;
       // MobileNo = "91" + 9899906658;
        string url = "http://www.universalsmsadvertising.com/universalsmsapi.php?user_name=9837016352&user_password=9837016352&mobile=" + MobileNo + "&sender_id=TMUniv&type=F&text=" + Msg + "";
        System.Net.HttpWebRequest fr;
        Uri targetURI = new Uri(url);
        fr = (System.Net.HttpWebRequest)System.Net.HttpWebRequest.Create(targetURI);
        if (fr.GetResponse().ContentLength > 0)
        {
            System.IO.StreamReader str = new System.IO.StreamReader(fr.GetResponse().GetResponseStream());
            Response.Write(str.ReadToEnd());
            str.Close();
        }
    }
    protected void btnSendOTP_Click(object sender, EventArgs e)
    {
        lblOTPmasg.Text = "";
        if (txtAppEnquiryNo.Text == "" || txtAppMobileNo.Text == "")
        {
            lblOTPmasg.Text = " Fill Enquiry No/Mobile No !!";
            return;
        }
        string OTPGen = apdl.UpdateandGenerateOTPForApplicant(txtAppEnquiryNo.Text, txtAppMobileNo.Text);
        string Msg = "Your OTP No is:" + OTPGen + " ";


        if (OTPGen.Length <= 10 && OTPGen.Length > 1)
        {
            Boolean SendMsg = false;
            SendMsg = SendMessage(txtAppMobileNo.Text, Msg);//Message 
            if (SendMsg == true)
            {
               lblMsg.Text = "OTP has been sent to your Registered Mobile No !";
                rblRegStep.SelectedIndex = 1;
                if (rblRegStep.SelectedIndex == 1)
                {
                    dvOTP.Visible = true;
                    dvEnquiry.Visible = false;
                    dvAppDetails.Visible = false;
                    dvApplication.Visible = true;
                    dvFamily.Visible = false;
                    dvAddress.Visible = false;
                    dvQualification.Visible = false;
                }
            }
            else
            {
                lblMsg.Text = "Something went wrong Try Again....";
            }
        }
        else
        {
            lblMsg.Text = OTPGen;
        }


    }
    public bool SendMessage(string MobileNo, string Message)
    {
        MobileNo = MobileNo.Substring(MobileNo.Length - 10, 10);
        SMS(MobileNo, Message);
        return true;

    }
    protected void btnValidateOTP_Click(object sender, EventArgs e)
    {
        Prequalification();
        lblOTPmasg.Text = "";
        if (txtAppEnquiryNo.Text == "" || txtAppMobileNo.Text == "" || txtOTP.Text == "")
        {
            lblOTPmasg.Text = " Fill Enquiry No/Mobile No/OTP !!";
            return;
        }
        BindData();
        if (lblMsg.Text == "")
        {
            rblRegStep.SelectedIndex = 1;
            if (rblRegStep.SelectedIndex == 1)
            {
                dvEnquiry.Visible = false;
                dvOTP.Visible = false;
                dvAppDetails.Visible = true;
                dvApplication.Visible = true;
                dvFamily.Visible = true;
                dvAddress.Visible = true;
                dvQualification.Visible = true;

            }
            if (dvAppDetails.Visible == false)
            {
                btnSave.Visible = false;
            }
            else
            {
                btnSave.Visible = true;
            }
        }
    }
