    public void BindData()
    {
        hfApplicationNo.Value = "";
        lblMsg.Text = "";
        DataTable dtData = new DataTable();
        dtData = apdl.GetDataAfterValidateOTP(txtAppEnquiryNo.Text, txtAppMobileNo.Text, txtOTP.Text);
        if (dtData.Rows.Count > 0)
        {
            if (dtData.Rows[0]["Error"].ToString() == "")
            {
                hfApplicationNo.Value = dtData.Rows[0]["ApplicationNo"].ToString();
                txtApplicantName.Text = dtData.Rows[0]["Applicant Name"].ToString();
                if (dtData.Rows[0]["Academic Year"].ToString() != "")
                {
                    drpAcademicYear.SelectedValue = dtData.Rows[0]["Academic Year"].ToString();
                }
                drpCourse.SelectedValue = dtData.Rows[0]["Course Code"].ToString();
                drpCourse.Enabled = false;
                drpPrequalification.SelectedValue = dtData.Rows[0]["Prequalification"].ToString();
                drpGender.SelectedValue = dtData.Rows[0]["Gender"].ToString();

                if (dtData.Rows[0]["Medium of Instruction"].ToString() == "" || dtData.Rows[0]["Medium of Instruction"].ToString() == "0")
                    drpMedium.SelectedValue = "";
                else
                    drpMedium.SelectedValue = dtData.Rows[0]["Medium of Instruction"].ToString();
                txtPreviousInst.Text = dtData.Rows[0]["Name of the Previous Institute"].ToString();

                DateTime dt = Convert.ToDateTime(dtData.Rows[0]["Date of Birth"]);
                var text = dt.ToString("dd MMM yyyy");
                if (text == "01 Jan 1753")
                { txtYear.Text = ""; txtmonths.Text = ""; txtDOB.Text = ""; }
                else
                { txtDOB.Text = text; txtYear.Text = dtData.Rows[0]["Age"].ToString(); txtmonths.Text = dtData.Rows[0]["Months"].ToString(); }

                txtFatherName.Text = dtData.Rows[0]["Father_s Name"].ToString();
                txtMotherName.Text = dtData.Rows[0]["Mother_s Name"].ToString();
                //Application--------Start--
                txtAadharNo.Text = dtData.Rows[0]["Aadhar No_"].ToString();
                txtEmailAddress.Text = dtData.Rows[0]["E-Mail Address"].ToString();
                txtFacebookId.Text = dtData.Rows[0]["Facebook ID"].ToString();
                //Application--------END--


                DataSet ds = new DataSet();
                ds = cdl.getApplicationCost(drpCourse.SelectedValue, drpQuota.SelectedItem.Text);
                if (ds.Tables[0].Rows.Count > 0) { lblApplicationCost.Text = ds.Tables[0].Rows[0]["Application Cost"].ToString(); }
                if (dtData.Rows[0]["ApplicationNo"].ToString() == "")
                {
                    drpCitizen.SelectedValue = dtData.Rows[0]["ApplicantStatus"].ToString();
                    drpQuota.SelectedValue = dtData.Rows[0]["Category"].ToString();
                }
                else
                {
                    drpCitizen.SelectedValue = dtData.Rows[0]["Citizenship"].ToString();
                    drpQuota.SelectedValue = dtData.Rows[0]["Category"].ToString();
                    txtFatherQualification.Text = dtData.Rows[0]["Father_s Qualification"].ToString();
                    txtFatherOccupation.Text = dtData.Rows[0]["Father_s Occupation"].ToString();
                    txtFatherAnnualIncome.Text = dtData.Rows[0]["Father_s Annual Income"].ToString();
                    txtMotherQualification.Text = dtData.Rows[0]["Mother_s Qualification"].ToString();
                    txtMotherOccupation.Text = dtData.Rows[0]["Mother_s Occupation"].ToString();
                    txtMotherAnnualIncome.Text = dtData.Rows[0]["Mother_s Annual Income"].ToString();
                    //------------new add------18-04-2015--------------                   
                    // txtParentContact.Text = dtData.Rows[0]["Parents Mobile Number"].ToString();

                    ddlRegidanceStatus.SelectedValue = dtData.Rows[0]["Resident Status"].ToString();
                    ddlMaritalStatus.SelectedValue = dtData.Rows[0]["Marital Status"].ToString();
                    txtMotherTounge.Text = dtData.Rows[0]["Mother Tongue"].ToString();
                    ddlReligion.SelectedValue = dtData.Rows[0]["Religion"].ToString();
                    if (ddlReligion.SelectedValue.ToUpper() == "JAIN")
                    {
                        ddlSubReligion.Visible = true;
                        lblSubReligionNotRequired.Visible = false;
                    }
                    else
                    {
                        ddlSubReligion.Visible = false;
                        lblSubReligionNotRequired.Visible = true;
                    }       
        
                    ddlSubReligion.SelectedValue = dtData.Rows[0]["Sub Religion"].ToString();
                    txtParentContact.Text = dtData.Rows[0]["Parents Phone Number"].ToString();
                    txtParentEmail.Text = dtData.Rows[0]["Parents Email Id"].ToString();
                    ddlDisability.SelectedValue = dtData.Rows[0]["Disability"].ToString();
                    ddlDomicile.SelectedValue = dtData.Rows[0]["State"].ToString();
                    //------Address-----
                    txtPermAddress.Text = dtData.Rows[0]["Address1"].ToString();
                    ddlPermCity.SelectedValue = dtData.Rows[0]["City"].ToString();
                    txtPermPinCode.Text = dtData.Rows[0]["Post Code"].ToString();
                    ddlPermState.SelectedValue = dtData.Rows[0]["State"].ToString();
                    ddlPermDistrict.SelectedValue = dtData.Rows[0]["District"].ToString();
                    if (dtData.Rows[0]["Same As Permanent Address"].ToString() == "1")
                    { chkSameAddress.Checked = true;
                   
                    }
                    else { chkSameAddress.Checked = false; }

                    txtCorresAddress.Text = dtData.Rows[0]["Address3"].ToString();
                    ddlCorresCity.SelectedValue = dtData.Rows[0]["Cor City"].ToString();
                    txtCorresPinCode.Text = dtData.Rows[0]["Cor Post Code"].ToString();
                    ddlCorresState.SelectedValue = dtData.Rows[0]["Cor State"].ToString();
                    ddlCorresDistrict.SelectedValue = dtData.Rows[0]["Cor District"].ToString();
                    ChkAddress();
                    if (dtData.Rows[0]["Record of Criminal Case"].ToString() == "1") { rblCase.SelectedValue = "1"; }
                    else { rblCase.SelectedValue = "0"; }

                    ViewState["StudentImage"] = (Byte[])dtData.Rows[0]["Applicant Image"];
                    String Proc = "proc_GetImageByEnquiryId";
                    imgApplicant.ImageUrl = "image.aspx?ImageID=" + txtAppEnquiryNo.Text + "&Proc=" + Proc + "";
                    DataTable dtQual = new DataTable();
                    dtQual = apdl.GetQualificationDataAfterValidateOTP(txtAppEnquiryNo.Text);
                    grdQualification.DataSource = dtQual;
                    grdQualification.DataBind();
                    ViewState["Qualification"] = dtQual;


                }
            }
            else
            {
                lblMsg.Text = dtData.Rows[0]["Error"].ToString();
            }
        }
    }
