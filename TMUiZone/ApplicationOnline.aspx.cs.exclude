    protected void btnAdd_Click(object sender, EventArgs e)
    {
        lblerror.Text = "";
        if (ddlExamination.SelectedItem.Text == "-- Select --")
            lblerror.Text = "please fill all the fields.";
        else
        {
            if (grdQualification.Rows.Count > 0)
            {
                dtqualification = (DataTable)ViewState["Qualification"];
                DataView dv = new DataView(dtqualification);
                dv.RowFilter = "Qualification='" + ddlExamination.SelectedValue + "'";
                //dt.DefaultView.RowFilter = "SubjectCode="+drpPrequalificationSubCode.SelectedItem.Text+"";
                if (dv.Count > 0)
                {
                    lblerror.Text = "Qualification code already exist.";
                }
                else if (txtPercentageOfMarks.Text == "" && txtGrade.Text == "")
                {
                    lblerror.Text = "please fill % Marks or Grade.";
                }
                else
                {
                    dtqualification.Rows.Add(ddlExamination.SelectedValue, ddlExamination.SelectedItem.Text, txtDescription.Text, txtYearofPassing.Text, txtSchoolCollege.Text, txtNameOfBoardUniv.Text,
                        txtMaximum.Text, txtMarkObtained.Text,Convert.ToDecimal(txtPercentageOfMarks.Text), txtGrade.Text, txtMediumOfInstruction.Text, txtDesciplineSubj.Text);
                    grdQualification.DataSource = dtqualification;
                    grdQualification.DataBind();
                    blankTable();
                }
            }
            else
            {
                if (txtPercentageOfMarks.Text == "" && txtGrade.Text == "")
                {
                    lblerror.Text = "please fill Percent or Marks.";
                }
                else
                {
                    dtqualification.Columns.AddRange(new DataColumn[12]{
                    new DataColumn ("Qualification",typeof(int)),                    
                    new DataColumn ("QualificationDesc",typeof(string)),
                    new DataColumn ("Description",typeof(string)),
                    new DataColumn ("YearOfPassing",typeof(string)),
                    new DataColumn ("SchoolCollege",typeof(string)),
                    new DataColumn ("BoardUniversity",typeof(string)),
                    new DataColumn ("MaximumMarks",typeof(string)),
                    new DataColumn ("MarksObtained",typeof(string)),                    
                    new DataColumn ("PMarks",typeof(decimal)),
                    new DataColumn ("Grade",typeof(string)),
                    new DataColumn ("MOI",typeof(string)),
                    new DataColumn ("DesciplineSubj",typeof(string))                    
                    });
                    dtqualification.Rows.Add(ddlExamination.SelectedValue, ddlExamination.SelectedItem.Text, txtDescription.Text, txtYearofPassing.Text, txtSchoolCollege.Text, txtNameOfBoardUniv.Text,
                        txtMaximum.Text, txtMarkObtained.Text, Convert.ToDecimal(txtPercentageOfMarks.Text), txtGrade.Text, txtMediumOfInstruction.Text, txtDesciplineSubj.Text);
                    grdQualification.DataSource = dtqualification;
                    grdQualification.DataBind();
                    ViewState["Qualification"] = dtqualification;
                    blankTable();
                }
            }
        }
    }
    public void blankTable()
    {
        ddlExamination.SelectedIndex = 0;
        txtYearofPassing.Text = "";
        txtSchoolCollege.Text = "";
        txtNameOfBoardUniv.Text = "";
        txtMaximum.Text = "";
