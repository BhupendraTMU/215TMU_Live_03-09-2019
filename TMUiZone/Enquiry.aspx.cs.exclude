                ScriptManager.RegisterStartupScript(this, this.GetType(), "", "Selector();", true);
            }
            catch (Exception ex)
            {

            }
        }
        protected void btnsubmit_Click(object sender, EventArgs e)
        {
            string result = "";
            try
            {
                SqlCommand cmd = new SqlCommand("sp_SaveEnquiry", con);//Insert_proc_MarksEntryHeader1
                cmd.CommandType = CommandType.StoredProcedure;
                cmd.Parameters.AddWithValue("@ApplicantName", txtUser.Text);//Session["GlobalDimension1Code"]
                cmd.Parameters.AddWithValue("@Mail", txtMail.Text);
                cmd.Parameters.AddWithValue("@CountryCode", drpCountryCode.SelectedValue);
                cmd.Parameters.AddWithValue("@Gender", drpGender.SelectedValue);
                cmd.Parameters.AddWithValue("@Mobile", txtMobile.Text);
                cmd.Parameters.AddWithValue("@State", txtState.SelectedValue);
                cmd.Parameters.AddWithValue("@City", txtcity.SelectedValue);
                cmd.Parameters.AddWithValue("@ProgramType", ddlStream.Text);
                cmd.Parameters.AddWithValue("@Stream", ddlProgramType.SelectedItem.Text);
                cmd.Parameters.AddWithValue("@Specialization", ddlSpecialization.SelectedItem.Text);
                cmd.Parameters.Add("@result", SqlDbType.VarChar, 500).Direction = ParameterDirection.Output;
                if (con.State == ConnectionState.Open)
                { con.Close(); }
                con.Open();
                cmd.ExecuteNonQuery();
                con.Close();

                result = cmd.Parameters["@result"].Value.ToString();
                if (result == "0")
                {
                    ScriptManager.RegisterStartupScript(this, this.GetType(), "alertMessage", "customAlert('E','Already Register');", true);
                }
                else
                {
                    ScriptManager.RegisterStartupScript(this, this.GetType(), "alertMessage", "customAlert('S','Enquiry No. " + result + " is generated successfully.');", true);
                }
                //Response.Redirect("EnquiryOnline.aspx");

            }
            catch (Exception Ex)
            {
                ScriptManager.RegisterStartupScript(this, this.GetType(), "", "Selector();", true);
                ScriptManager.RegisterStartupScript(this, this.GetType(), "alertMessage", "customAlert('E','Error... ');", true);
            }
        }

        protected void btnexist_Click(object sender, EventArgs e)
        {
            divenq.Visible = false;
            divlog.Visible = true;
        }
        protected void btnregistration_Click(object sender, EventArgs e)
        {
            Response.Redirect("Enquiry.aspx");
        }
        protected void btnlogin_Click(object sender, EventArgs e)
        {
            if (txtenno.Text == "")
            {
                txtenno.Focus();
                txtenno.BorderColor = Color.Red;
                ScriptManager.RegisterStartupScript(this, this.GetType(), "alertMessage", "customAlert('E','Enter Enquiry No');", true);
                return;
            }
            if (txtpassword.Text == "")
            {
                txtpassword.Focus();
                txtpassword.BorderColor = Color.Red;
                ScriptManager.RegisterStartupScript(this, this.GetType(), "alertMessage", "customAlert('E','Enter Password');", true);
                return;
            }
            if (txtenno.Text != "" && txtpassword.Text != "")
            {
                Response.Redirect("Application.aspx?invno=" + txtenno.Text + "&invp=" + txtpassword.Text);

            }
        }

