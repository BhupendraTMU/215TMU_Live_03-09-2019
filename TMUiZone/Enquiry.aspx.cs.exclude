    SqlConnection con = new SqlConnection(ConfigurationManager.ConnectionStrings["TMUCON"].ToString());
    protected void Page_Load(object sender, EventArgs e)
    {

        if (!IsPostBack)
        {

            bindCountryCode();
            BindProgramType();
            BindSate();
        }
    }
    
        public void bindCountryCode()
        {
            try
            {
                SqlCommand cmd = new SqlCommand("proc_GetCountryCode", con);
                cmd.CommandType = CommandType.StoredProcedure;
                SqlDataAdapter da = new SqlDataAdapter(cmd);
                DataSet ds = new DataSet();
                con.Open();
                da.Fill(ds);
                con.Close();


                drpCountryCode.DataSource = ds.Tables[0];
                drpCountryCode.DataTextField = "Details";
                drpCountryCode.DataValueField = "No_";
                drpCountryCode.DataBind();
                drpCountryCode.SelectedValue = "+91";
            }
            catch
            {
            }
        }

        public void BindSate()
        {
            try
            {
                SqlCommand cmd = new SqlCommand("proc_GetState", con);
                cmd.CommandType = CommandType.StoredProcedure;
                SqlDataAdapter da = new SqlDataAdapter(cmd);
                DataTable dt1 = new DataTable();
                con.Open();
                da.Fill(dt1);
                con.Close();
                txtState.DataSource = dt1;
                txtState.DataTextField = "Details";
                txtState.DataValueField = "No_";
                txtState.DataBind();
            }
            catch
            {
            }
        }

        public void BindStream(string ProgramType )
        {
            try
            {
                SqlCommand cmd = new SqlCommand("proc_GetStreamByDoc", con);
                cmd.Parameters.AddWithValue("@Code", ProgramType);
                
                cmd.CommandType = CommandType.StoredProcedure;
                SqlDataAdapter da = new SqlDataAdapter(cmd);
                DataSet ds = new DataSet();
                con.Open();
                da.Fill(ds);
                con.Close();
                ddlStream.DataSource = ds.Tables[0];
                ddlStream.DataTextField = "Details";
                ddlStream.DataValueField = "No_";
                ddlStream.DataBind();


            }
            catch
            {
            }
        }
        public void BindDdlCity(string Statecode)
        {
            try
            {
                SqlCommand cmd = new SqlCommand("proc_GetCityDdlByStateDistrict", con);

                cmd.CommandType = CommandType.StoredProcedure;

                cmd.Parameters.AddWithValue("@ID", Statecode);
                cmd.Parameters.AddWithValue("@ID1", Statecode);
                SqlDataAdapter da = new SqlDataAdapter(cmd);
                DataTable dt1 = new DataTable();
                con.Open();
                da.Fill(dt1);
                con.Close();
                txtcity.DataSource = dt1;
                txtcity.DataTextField = "Details";
                txtcity.DataValueField = "No_";
                txtcity.DataBind();

            }
            catch
            {
            }
        }



        public void BindSpecialization(string Streamcode,string ProgramCode)
        {
            try
            {
                SqlCommand cmd = new SqlCommand("proc_GetSpecialization", con);

                cmd.CommandType = CommandType.StoredProcedure;

                cmd.Parameters.AddWithValue("@SteamID", Streamcode);
                cmd.Parameters.AddWithValue("@Program", ddlStream.SelectedValue);
                SqlDataAdapter da = new SqlDataAdapter(cmd);
                DataTable dt1 = new DataTable();
                con.Open();
                da.Fill(dt1);
                con.Close();
                ddlSpecialization.DataSource = dt1;
                ddlSpecialization.DataTextField = "Details";
                ddlSpecialization.DataValueField = "No_";
                ddlSpecialization.DataBind();
            }
            catch
            {
            }
        }

        public void BindProgramType()
        {
            try
            {
                SqlCommand cmd = new SqlCommand("proc_GetProgramType", con);

                cmd.CommandType = CommandType.StoredProcedure;

              
                SqlDataAdapter da = new SqlDataAdapter(cmd);
                DataTable dt1 = new DataTable();
                con.Open();
                da.Fill(dt1);
                con.Close();
                ddlProgramType.DataSource = dt1;
                ddlProgramType.DataTextField = "Details";
                ddlProgramType.DataValueField = "No_";
                ddlProgramType.DataBind();
            }
            catch
            {
            }
        }

        [System.Web.Script.Services.ScriptMethod()]
        [System.Web.Services.WebMethod]
        public static string Save(string ContactNo, string Course, string Name, string City, string Email)
        {
            DL.CommonDL commonDl = new CommonDL();
            //----------------Duplicate---------Start
            string Result = commonDl.addApplicantInformation(ContactNo, Course);
            if (Result != "")
            {
                return "Error";
            }
            //----------------Duplicate-----End
            string No = "";
            EnquiryDL objEnquiryDL = new EnquiryDL();
            No = objEnquiryDL.GetNextEnquiryNo();
            ContactNo = "+91" + ContactNo;
            //---changes on 05-06-2016--by Saurabh-Email ID- add email ID
            commonDl.RegisterYourInterest(No, Name.ToUpper(), "", ContactNo, Course, "", "", "", 0, "WEBSITE", City, "", Email);
            return "You Have Registered Successfully with Enquiry No : " + No + "  ! ";
        }
