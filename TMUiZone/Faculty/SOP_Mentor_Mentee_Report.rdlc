                  <Height>0.78521cm</Height>
                  <TablixCells>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="Textbox284">
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>We are committed to realizing the highest potential of each student, supporting them to exceed both their own expectations and those set by their educators and caregivers. This policy outlines our strategies to achieve exceptional mentorship and guidance at Teerthanker Mahaveer University.</Value>
                                  <Style>
                                    <FontSize>7pt</FontSize>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style />
                            </Paragraph>
                          </Paragraphs>
                          <rd:DefaultName>Textbox284</rd:DefaultName>
