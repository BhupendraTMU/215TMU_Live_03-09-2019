								<td>
									<asp:Label ID="lbl_RequiredMinimumAPIScore_AssociateProfessor_130" runat="server" Text="130"></asp:Label></td>
								<td>
									<asp:Label ID="lbl_RequiredMinimumAPIScore_Professor_140" runat="server" Text="140"></asp:Label></td>


							</tr>

