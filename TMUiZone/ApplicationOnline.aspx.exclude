    <style type="text/css">
        .red-border {
            border: 1px solid red;
        }
    </style>
    <script>
        function callFeedbackMessage(inputType, inputText) {

            if (inputType == 'Error') {
                alertify.error("Upload Image and Try again !");
                return false;
            }
            else if (inputType == 'Error1') {
                //alertify.confirm().set('overflow', false);
                alertify.success("Add QUalification !");
                return false;
            }
            else {
                alertify.log(inputText, "", 10000);
                return false;
            }
        }
    </script>


    <script type="text/javascript">

        function CalculateAge(DOB) {
            debugger
            if (DOB.value != '') {
                now = new Date()
                dob = DOB.value.split('-');
                if (dob.length === 3) {
                    born = new Date(dob[2], dob[1] * 1 - 1, dob[0]);
                    age = Math.floor((now.getTime() - born.getTime()) / (365.25 * 24 * 60 * 60 * 1000));
                    day = Math.floor(now.getDate());
                    day1 = Math.floor(born.getDate());
                    if (day1 < day) {
                        month = Math.floor((now.getMonth() - born.getMonth()));
                    }
                    else {
                        month = Math.floor((now.getMonth() - born.getMonth())) - 1;
                    }
                    if (month < 0) {
                        month = 12 + month;
                    }
                    if (age < 0) {
                        $('[id$=txtYear]').val('0');
                        $('[id$=txtmonths]').val('0');
                    }
                    else {
                        $('[id$=txtYear]').val(age);
                        $('[id$=txtmonths]').val(month);
                        return false;
                    }
                }
            }
        }
        function checkDate(sender, args) {
            if (sender._selectedDate > new Date()) {
                alert("You cannot select greater than current date!");
                sender._selectedDate = new Date();
                sender._textbox.set_Value(sender._selectedDate.format(sender._format))
            }
        }
        function NumberOnly() {
            var AsciiValue = event.keyCode
            if ((AsciiValue >= 48 && AsciiValue <= 57) || (AsciiValue == 8 || AsciiValue == 127))
                event.returnValue = true;
            else
                event.returnValue = false;
        }

        function OnChangeCheckbox(lnk) {
            if (lnk.checked) {
                $('[id$=txtCorresAddress]').val($('[id$=txtPermAddress]').val());
                $('[id$=txtCorresPinCode]').val($('[id$=txtPermPinCode]').val());
                $('[id$=ddlCorresState]').val($('[id$=ddlPermState]').val());
                $('[id$=ddlCorresDistrict]').val($.trim($("[id*=ddlPermDistrict]").val()));
                $('[id$=ddlCorresCity]').val($.trim($("[id*=ddlPermCity]").val()));

                // alert($('[id$=ddlCorresDistrict]').val());

                $('[id$=txtCorresAddress]').attr("readonly", "readonly");
                $('[id$=txtCorresPinCode]').attr("readonly", "readonly");
                $('[id$=txtPermAddress]').attr("readonly", "readonly");
                $('[id$=txtPermPinCode]').attr("readonly", "readonly");
                $('[id$=ddlCorresState]').attr('disabled', true);
                $('[id$=ddlCorresDistrict]').attr('disabled', true);
                $('[id$=ddlCorresCity]').attr('disabled', true);
                $('[id$=ddlPermState]').attr('disabled', true);
                $('[id$=ddlPermDistrict]').attr('disabled', true);
                $('[id$=ddlPermCity]').attr('disabled', true);
            }
            else {

                $('[id$=txtCorresAddress]').val('');
                $('[id$=ddlCorresState]').val('');
                $('[id$=ddlCorresDistrict]').val('')
                $('[id$=ddlCorresCity]').val('');
                $('[id$=txtCorresPinCode]').val('');

                $('[id$=txtCorresAddress]').removeAttr("readonly");
                $('[id$=ddlCorresState]').attr('disabled', false);
                $('[id$=ddlCorresDistrict]').attr('disabled', false);
                $('[id$=txtCorresPinCode]').removeAttr("readonly");
                $('[id$=ddlCorresCity]').attr('disabled', false);
                $('[id$=txtPermAddress]').removeAttr("readonly");
                $('[id$=ddlPermState]').attr('disabled', false);
                $('[id$=ddlPermDistrict]').attr('disabled', false);
                $('[id$=ddlPermCity]').attr('disabled', false);
                $('[id$=txtPermPinCode]').removeAttr("readonly");

            }
        }

    </script>
    <script type="text/javascript">

        function validateLength(oSrc, args) {
            args.IsValid = (parseInt($('[id$=txtMaximum]').val()) >= parseInt($('[id$=txtMarkObtained]').val()));
        }

        function ShowImagePreview(input) {
            debugger
            if (input.files && input.files[0]) {

                var reader = new FileReader();
                reader.onload = function (e) {
                    $('#imgApplicant').attr('src', e.target.result);
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
    <script type="text/javascript">
        function GenerateNo() {
            $('[id$=txtEnqApplicantName]').css('border-color', 'red');;
            $('[id$=ddlEnqCourse]').css('border-color', 'red');
            $('[id$=txtEnqMobileNo]').css('border-color', 'red');

            var a = '';
            if ($('[id$=txtEnqApplicantName]').val() == '') { a = "false" } else $('[id$=txtEnqApplicantName]').css('border-color', '');
            if ($('[id$=ddlEnqCourse]').val() == '') { a = "false" } else $('[id$=ddlEnqCourse]').css('border-color', '');
            if ($('[id$=txtEnqMobileNo]').val().length < 10) { a = "false" } else $('[id$=txtEnqMobileNo]').css('border-color', '');
            if (a == "false") { return false; }
        }
        function OTPsend() {
            $('[id$=txtAppEnquiryNo]').css('border-color', 'red');;
            $('[id$=txtAppMobileNo]').css('border-color', 'red');

            var a = '';
            if ($('[id$=txtAppEnquiryNo]').val().length < 14) { a = "false" } else $('[id$=txtAppEnquiryNo]').css('border-color', '');
            if ($('[id$=txtAppMobileNo]').val().length < 10) { a = "false" } else $('[id$=txtAppMobileNo]').css('border-color', '');
            if (a == "false") { return false; }
        }
        function OTPvalidate() {
            $('[id$=txtAppEnquiryNo]').css('border-color', 'red');
            $('[id$=txtAppMobileNo]').css('border-color', 'red');
            $('[id$=txtOTP]').css('border-color', 'red');

            var a = '';
            if ($('[id$=txtAppEnquiryNo]').val().length < 14) { a = "false" } else $('[id$=txtAppEnquiryNo]').css('border-color', '');
            if ($('[id$=txtAppMobileNo]').val().length < 10) { a = "false" } else $('[id$=txtAppMobileNo]').css('border-color', '');
            if ($('[id$=txtOTP]').val().length < 4) { a = "false" } else $('[id$=txtOTP]').css('border-color', '');
            if (a == "false") { return false; }//alert("ashu");
        }
        function Upload() {

            debugger
            $('[id$=imgUpload]').css('border-color', 'red');
            if ($('[id$=imgUpload]').val() == '') { return false; } else $('[id$=imgUpload]').css('border-color', '');

        }
        function add() {
            $('[id$=txtAppEnquiryNo]').css('border-color', 'red');
            $('[id$=txtAppMobileNo]').css('border-color', 'red');
            $('[id$=txtOTP]').css('border-color', 'red');

            var a = '';
            if ($('[id$=txtAppEnquiryNo]').val().length < 14) { a = "false" } else $('[id$=txtAppEnquiryNo]').css('border-color', '');
            if ($('[id$=txtAppMobileNo]').val().length < 10) { a = "false" } else $('[id$=txtAppMobileNo]').css('border-color', '');
            if ($('[id$=txtOTP]').val().length < 4) { a = "false" } else $('[id$=txtOTP]').css('border-color', '');
            if (a == "false") { return false; }//alert("ashu");
        }
    </script>

    <script type="text/javascript">
        function preventBackspace(e) {
            var evt = e || window.event;
            if (evt) {
                var keyCode = evt.charCode || evt.keyCode;
                if (keyCode === 8) {
                    if (evt.preventDefault) {
                        evt.preventDefault();
                    } else {
                        evt.returnValue = false;
                    }
                }
            }
        }

    </script>
    <script type="text/javascript">


        function SAVE() {

            var a = '';
            var rowsCount = <%#grdQualification.Rows.Count %>
           $('[id$=txtApplicantName]').css('border-color', 'red');
            if ($('[id$=txtApplicantName]').val() == '') { a = "false" } else $('[id$=txtApplicantName]').css('border-color', '');
            $('[id$=drpCourse]').addClass("red-border");
            if ($('[id$=drpCourse]').val() == '') { a = "false" } else $('[id$=drpCourse]').removeClass("red-border");
            $('[id$=drpPrequalification]').addClass("red-border");
            if ($('[id$=drpPrequalification]').val() == '') { a = "false" } else $('[id$=drpPrequalification]').removeClass("red-border");
            $('[id$=drpGender]').addClass("red-border");
            if ($('[id$=drpGender]').val() == '0') { a = "false" } else $('[id$=drpGender]').removeClass("red-border");
            $('[id$=drpAcademicYear]').addClass("red-border");
            if ($('[id$=drpAcademicYear]').val() == '') { a = "false" } else $('[id$=drpAcademicYear]').removeClass("red-border");
            $('[id$=drpCitizen]').addClass("red-border");
            if ($('[id$=drpCitizen]').val() == '') { a = "false" } else $('[id$=drpCitizen]').removeClass("red-border");
            $('[id$=ddlRegidanceStatus]').addClass("red-border");
            if ($('[id$=ddlRegidanceStatus]').val() == '0') { a = "false" } else $('[id$=ddlRegidanceStatus]').removeClass("red-border");
            $('[id$=ddlMaritalStatus]').addClass("red-border");
            if ($('[id$=ddlMaritalStatus]').val() == '0') { a = "false" } else $('[id$=ddlMaritalStatus]').removeClass("red-border");
            $('[id$=txtMotherTounge]').css('border-color', 'red');
            if ($('[id$=txtMotherTounge]').val() == '') { a = "false" } else $('[id$=txtMotherTounge]').css('border-color', '');
            $('[id$=ddlReligion]').addClass("red-border");
            if ($('[id$=ddlReligion]').val() == '') { a = "false" } else $('[id$=ddlReligion]').removeClass("red-border");
            $('[id$=drpMedium]').addClass("red-border");
            if ($('[id$=drpMedium]').val() == '') { a = "false"; } else $('[id$=drpMedium]').removeClass("red-border");
            $('[id$=drpQuota]').addClass("red-border");
            if ($('[id$=drpQuota]').val() == '') { a = "false" } else $('[id$=drpQuota]').removeClass("red-border");
            $('[id$=txtPreviousInst]').css('border-color', 'red');
            if ($('[id$=txtPreviousInst]').val() == '') { a = "false" } else $('[id$=txtPreviousInst]').css('border-color', '');
            $('[id$=txtDOB]').css('border-color', 'red');
            if ($('[id$=txtDOB]').val() == '') { a = "false" } else $('[id$=txtDOB]').css('border-color', '');
            $('[id$=txtFatherName]').css('border-color', 'red');
            if ($('[id$=txtFatherName]').val() == '') { a = "false" } else $('[id$=txtFatherName]').css('border-color', '');
            $('[id$=txtMotherName]').css('border-color', 'red');
            if ($('[id$=txtMotherName]').val() == '') { a = "false" } else $('[id$=txtMotherName]').css('border-color', '');
            $('[id$=txtEmailAddress]').css('border-color', 'red');
            if ($('[id$=txtEmailAddress]').val() == '') { a = "false" } else $('[id$=txtEmailAddress]').css('border-color', '');
            $('[id$=ddlDisability]').addClass("red-border");
            if ($('[id$=ddlDisability]').val() == '') { a = "false" } else $('[id$=ddlDisability]').removeClass("red-border");
            $('[id$=ddlDomicile]').addClass("red-border");
            if ($('[id$=ddlDomicile]').val() == '') { a = "false" } else $('[id$=ddlDomicile]').removeClass("red-border");
            $('[id$=drpModeOfPayment]').addClass("red-border");
            if ($('[id$=drpModeOfPayment]').val() == '0') { a = "false" } else $('[id$=drpModeOfPayment]').removeClass("red-border");
            $('[id$=lblApplicationCost]').css('border-color', 'red');
            if ($('[id$=lblApplicationCost]').text == '') { a = "false" } else $('[id$=lblApplicationCost]').css('border-color', '');

            $('[id$=txtPermAddress]').css('border-color', 'red');
            if ($('[id$=txtPermAddress]').val() == '') { a = "false" } else $('[id$=txtPermAddress]').css('border-color', '');
            $('[id$=ddlPermState]').addClass("red-border");
            if ($('[id$=ddlPermState]').val() == '') { a = "false" } else $('[id$=ddlPermState]').removeClass("red-border");
            $('[id$=ddlPermDistrict]').addClass("red-border");
            if ($.trim($("[id*=ddlPermDistrict]").val()) == '') { a = "false" } else $('[id$=ddlPermDistrict]').removeClass("red-border");
            $('[id$=ddlPermCity]').addClass("red-border");
            if ($.trim($("[id*=ddlPermCity]").val()) == '') { a = "false" } else $('[id$=ddlPermCity]').removeClass("red-border");
            $('[id$=txtPermPinCode]').css('border-color', 'red');
            if ($('[id$=txtPermPinCode]').val() == '') { a = "false" } else $('[id$=txtPermPinCode]').css('border-color', '');


            $('[id$=txtCorresAddress]').css('border-color', 'red');
            if ($('[id$=txtCorresAddress]').val() == '') { a = "false" } else $('[id$=txtCorresAddress]').css('border-color', '');
            $('[id$=ddlCorresState]').addClass("red-border");
            if ($('[id$=ddlCorresState]').val() == '') { a = "false" } else $('[id$=ddlCorresState]').removeClass("red-border");
            $('[id$=ddlCorresDistrict]').addClass("red-border");
            if ($.trim($("[id*=ddlCorresDistrict]").val()) == '') { a = "false" } else $('[id$=ddlCorresDistrict]').removeClass("red-border");
            $('[id$=ddlCorresCity]').addClass("red-border");
            if ($.trim($("[id*=ddlCorresCity]").val()) == '') { a = "false" } else $('[id$=ddlCorresCity]').removeClass("red-border")
            $('[id$=txtCorresPinCode]').css('border-color', 'red');
            if ($('[id$=txtCorresPinCode]').val() == '') { a = "false" } else $('[id$=txtCorresPinCode]').css('border-color', '');



            var x = $('[id$=txtEmailAddress]').val();
            var atpos = x.indexOf("@");
            var dotpos = x.lastIndexOf(".");

            if (atpos < 1 || dotpos < atpos + 2 || dotpos + 2 >= x.length) {
                $('[id$=txtEmailAddress]').css('border-color', 'red');
                a = "false"
            }
            else
                $('[id$=txtEmailAddress]').css('border-color', '');

            if (rowsCount = 0) { a = "false"; alert(rowsCount); } else;
            if (a == "false") { alertify.success("Please fill the mandatory field !"); return false; }


        }
    </script>

    <title>Apply Online</title>
</head>
<body>
    <form id="form1" runat="server">
        <asp:ScriptManager ID="ScriptManager1" runat="server"></asp:ScriptManager>
        <asp:UpdatePanelAnimationExtender ID="UpdatePanelAnimationExtender1"
            TargetControlID="UpdatePanel1" runat="server">
            <Animations>
            <OnUpdating>
               <Parallel duration="0">
                    <ScriptAction Script="onUpdating();" />
                    <EnableAction AnimationTarget="ddlReaapear" Enabled="false" /> 
                </Parallel>
            </OnUpdating>
            </Animations>
        </asp:UpdatePanelAnimationExtender>
        <div style="width: 100%;">

            <div class="container" style="padding-left: 0px; width: 100%; margin-top: -25px; padding-right: 0px">
                <br />
                <div class="row">
                    <div class="col-lg-12" style="width: 100%">

                        <div class="panel panel-info" style="border-color: #ACE9FB; background-color: #ACE9FB">
                            <div class="panel-heading" style="background-color: #ACE9FB; height: 35px; cursor: pointer" id="head">
                                <center>
                        <div class="panel-title" id="head1" "><b><p  style="color:white;font-size:15px"> Application Form</p></b></div> </center>
                            </div>
                            <asp:UpdatePanel ID="UpdatePanel1" runat="server">
                                <ContentTemplate>
                                    <%--Registration Steps-------Start----%>
                                    <div style="background-color: #ffd800">
                                        <asp:RadioButtonList ID="rblRegStep" runat="server" Width="300px" Style="padding-left: 20px; margin-right: 15px; display: inline" RepeatDirection="Horizontal"
                                            AutoPostBack="true" OnSelectedIndexChanged="rblRegStep_SelectedIndexChanged">
                                            <asp:ListItem Selected="True" style="margin-right: 20px">1.Generate Enquiry No</asp:ListItem>
                                            <asp:ListItem>2.Fill Application Form</asp:ListItem>
                                            <%--<asp:ListItem>3.Payment</asp:ListItem>--%>
                                        </asp:RadioButtonList>

                                    </div>

                                    <%--Registration Steps-------End----%>
                                    <%--Generate Enquiry No-------Start----%>

                                    <div id="dvEnquiry" class="panel panel-info" runat="server" style="border-color: #ACE9FB">
                                        <div style="background-color: #ACE9FB; color: white; font-size: 15px; text-align: center" id="Div3">
                                            <center>
                                  <b> Generate Enquiry No</b>
                                        </div>
                                        <div class="panel-body" id="Div1">

                                            <div class="col-lg-2" style="padding-left: 0px; font-size: 12px;">
                                                <div class="form-group">
                                                    <asp:Label ID="Label27" Style="line-height: 30px" runat="server" Text="Label"><b>*Name</b></asp:Label>
                                                </div>
                                            </div>
                                            <div class="col-lg-4" style="padding-left: 0px;">
                                                <div class="form-group">
                                                    <div class="input-group">
                                                        <span class="input-group-addon"><span class="glyphicon glyphicon-education"></span></span>
                                                        <asp:TextBox ID="txtEnqApplicantName" Name="" runat="server" CssClass="form-control input-sm" placeholder="Applicant Name" MaxLength="50"></asp:TextBox>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-lg-2" style="padding-right: 0px; font-size: 12px;">
                                                <div class="form-group">
                                                    <asp:Label ID="Label28" Style="line-height: 30px" runat="server" Text="Label"><b>*Course</b></asp:Label>
                                                </div>
                                            </div>
                                            <div class="col-lg-4" style="padding-right: 0px;">
                                                <div class="form-group">
                                                    <div class="input-group">
                                                        <span class="input-group-addon"><span class="glyphicon glyphicon-education"></span></span>
                                                        <asp:DropDownList ID="ddlEnqCourse" CssClass="form-control input-sm" runat="server">
                                                        </asp:DropDownList>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-lg-2" style="padding-left: 0px; font-size: 12px;">
                                                <div class="form-group">
                                                    <asp:Label ID="Label35" Style="line-height: 30px" runat="server" Text="Label"><b>*Mobile No </b></asp:Label>
                                                </div>
                                            </div>
                                            <div class="col-lg-4" style="padding-left: 0px;">
                                                <div class="col-lg-4" style="padding-left: 0px;">
                                                    <div class="form-group">
                                                        <div class="input-group">
                                                            <span class="input-group-addon"><span class="glyphicon glyphicon-earphone"></span></span>
                                                            <asp:Label ID="txtcontactPrefix" runat="server" Text="+91" CssClass="form-control input-sm"></asp:Label>
                                                        </div>

                                                    </div>
                                                </div>
                                                <div class="col-lg-8" style="padding-right: 0px;">
                                                    <div class="form-group">
                                                        <asp:TextBox ID="txtEnqMobileNo" CssClass="form-control input-sm" runat="server" MaxLength="10" onkeypress="return NumberOnly()"></asp:TextBox>

                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-lg-2" style="font-size: 12px;">
                                                <div class="form-group">
                                                    <asp:Label ID="Label22" Style="line-height: 30px" runat="server" Text="Label"><b>Whatsapp No</b></asp:Label>
                                                </div>
                                            </div>
                                            <div class="col-lg-4" style="padding-right: 2px;">
                                                <div class="col-lg-4">
                                                    <div class="form-group">
                                                        <div class="input-group" style="padding-right: 6px;">
                                                            <span class="input-group-addon"><span class="glyphicon glyphicon-earphone"></span></span>
                                                            <asp:Label ID="Label3" runat="server" Text="+91" CssClass="form-control input-sm"></asp:Label>
                                                        </div>

                                                    </div>
                                                </div>
                                                <div class="col-lg-8" style="padding-right: 0px;">
                                                    <div class="form-group">
                                                        <asp:TextBox ID="txtWhatsappNo" CssClass="form-control input-sm" runat="server" MaxLength="10" onkeypress="return NumberOnly()"></asp:TextBox>

                                                    </div>
                                                </div>
                                            </div>


                                            <div class="col-lg-12 text-right" style="padding-right: 0px; font-size: 12px;">
                                                <div class="form-group">
                                                    <asp:LinkButton ID="btnEnqNoGenerate" type="button" class="btn btn-info" runat="server" OnClick="btnEnqNoGenerate_Click" OnClientClick="return GenerateNo();">
                                                            <span class="glyphicon glyphicon-refresh"></span> NEXT
                                                    </asp:LinkButton>
                                                    <%--<asp:Button ID="btnEnqNoGenerate"   runat="server" Text="Generate No" CssClass="btn-lg btn-primary btn-block" OnClick="btnEnqNoGenerate_Click" ></asp:Button> --%>
                                                </div>
                                            </div>



                                        </div>

                                    </div>
                                    <%--Generate Enquiry No-------End---%>
                                    <%--Application-------Start---%>
                                    <div id="dvApplication" class="panel panel-info" runat="server" style="border-color: #ACE9FB">
                                        <div style="background-color: #ACE9FB; color: white; font-size: 15px; text-align: center" id="Div8">
                                            <center>                                 
                               <b> Applicant details</b>
                                        </div>
                                        <div id="dvOTP" class="panel panel-info" runat="server" style="border-color: #ACE9FB">
                                            <div class="panel-body" id="Div10">
                                                <div class="col-lg-2" style="padding-left: 0px; font-size: 12px;">
                                                    <div class="form-group">
                                                        <asp:Label ID="lblEnquiryNo" Style="line-height: 30px" runat="server" Text="Label"><b>*Enquiry No</b></asp:Label>
                                                    </div>
                                                </div>
                                                <div class="col-lg-4" style="padding-left: 0px;">
                                                    <div class="form-group">
                                                        <div class="input-group">
                                                            <span class="input-group-addon"><span class="glyphicon glyphicon-education"></span></span>
                                                            <asp:TextBox ID="txtAppEnquiryNo" Name="" runat="server" CssClass="form-control input-sm" placeholder="Enquiry No" MaxLength="15"></asp:TextBox>
                                                        </div>
