                                        </div>
                                        <asp:Panel ID="pnlQualification" runat="server" ScrollBars="Horizontal" Width="100%">
                                            <div class="panel-body" id="body3">

                                                <table class="table">

                                                    <tr>
                                                        <th style="font-size: 15px">Qualification&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</th>
                                                        <th style="font-size: 15px">Description&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</th>
                                                        <th style="font-size: 15px">Year of Passing</th>
                                                        <th style="font-size: 15px">School/College</th>
                                                        <th style="font-size: 15px">Name of Board/Univ</th>
                                                        <th style="font-size: 15px">Max Marks </th>
                                                        <th style="font-size: 15px">Marks Obtained</th>
                                                        <th style="font-size: 15px">Marks%</th>
                                                        <th style="font-size: 15px">Grade</th>
                                                        <th style="font-size: 15px">Medium of Instruction</th>
                                                        <th style="font-size: 15px">Descipline/Subjects</th>

                                                        <th style="font-size: 15px"></th>

                                                    </tr>
                                                    <tr>
                                                        <td>
                                                            <asp:DropDownList ID="ddlExamination" CssClass="form-control input-sm" runat="server"></asp:DropDownList>
                                                            <asp:RequiredFieldValidator ID="rfvExamination" runat="server" ControlToValidate="ddlExamination" ErrorMessage="* Select pre Qualification" ForeColor="Red" ValidationGroup="gAdd" InitialValue=""></asp:RequiredFieldValidator>


                                                        </td>
                                                        <td>
                                                            <asp:TextBox ID="txtDescription" CssClass="form-control input-sm" runat="server" Width="200px" MaxLength="50"></asp:TextBox>
                                                            <asp:RequiredFieldValidator ID="rfvtxtDescription" runat="server" ControlToValidate="txtDescription" ErrorMessage="* Description" ForeColor="Red" ValidationGroup="gAdd" InitialValue=""></asp:RequiredFieldValidator>

                                                        </td>
                                                        <td>
                                                            <asp:TextBox ID="txtYearofPassing" runat="server" CssClass="form-control input-sm" MaxLength="4" placeholder="Year of Passing" Width="50px"></asp:TextBox>
                                                            <asp:FilteredTextBoxExtender ID="FilteredTextBoxExtender5" runat="server" TargetControlID="txtYearofPassing" FilterType="Numbers, Custom"></asp:FilteredTextBoxExtender>
                                                            <asp:RegularExpressionValidator ID="RegularExpresphone2" ValidationGroup="gAdd" Display="Dynamic"
                                                                ControlToValidate="txtYearofPassing" runat="server" ForeColor="Red" ErrorMessage="Enter Valid Year!"
                                                                SetFocusOnError="True" ValidationExpression="^\d{4}$"></asp:RegularExpressionValidator>
                                                            <asp:RequiredFieldValidator ID="rfvtxtYearofPassing" runat="server" ControlToValidate="txtYearofPassing" ErrorMessage="* Year of Passing" ForeColor="Red" ValidationGroup="gAdd" InitialValue=""></asp:RequiredFieldValidator>
                                                        </td>
                                                        <td>

                                                            <asp:TextBox ID="txtSchoolCollege" runat="server" CssClass="form-control input-sm" placeholder="School/College" Width="200px" MaxLength="50"></asp:TextBox>
                                                            <asp:RequiredFieldValidator ID="rfvtxtSchoolCollege" runat="server" ControlToValidate="txtSchoolCollege" ErrorMessage="*School/College" ForeColor="Red" ValidationGroup="gAdd" InitialValue=""></asp:RequiredFieldValidator>

                                                        </td>
                                                        <td>
                                                            <asp:TextBox ID="txtNameOfBoardUniv" runat="server" CssClass="form-control input-sm" placeholder="Name of Board/Univ" Width="200px" MaxLength="50"></asp:TextBox>
                                                            <asp:RequiredFieldValidator ID="rfvtxtNameOfBoardUniv" runat="server" ControlToValidate="txtNameOfBoardUniv" ErrorMessage="*Board/Univ" ForeColor="Red" ValidationGroup="gAdd" InitialValue=""></asp:RequiredFieldValidator>

                                                        </td>
                                                        <td>
                                                            <asp:TextBox ID="txtMaximum" runat="server" CssClass="form-control input-sm" onchange="return Calculate();"
                                                                MaxLength="4" placeholder="Maximum" Width="50px"></asp:TextBox>
                                                            <asp:FilteredTextBoxExtender ID="FilteredTextBoxExtender3" runat="server" TargetControlID="txtMaximum" FilterType="Numbers, Custom"></asp:FilteredTextBoxExtender>
                                                            <asp:RequiredFieldValidator ID="rfvtxtMaximum" runat="server" ControlToValidate="txtMaximum" ErrorMessage="*Maximum" ForeColor="Red" ValidationGroup="gAdd" InitialValue=""></asp:RequiredFieldValidator>

                                                        </td>
                                                        <td>
                                                            <asp:TextBox ID="txtMarkObtained" runat="server" CssClass="form-control input-sm"
                                                                MaxLength="4" Width="50px"  OnTextChanged="txtMarkObtained_TextChanged" AutoPostBack="true" placeholder="Mark Obtained"></asp:TextBox>
                                                            <asp:FilteredTextBoxExtender ID="FilteredTextBoxExtender4" runat="server" TargetControlID="txtMarkObtained" FilterType="Numbers, Custom"></asp:FilteredTextBoxExtender>
                                                            <asp:RequiredFieldValidator ID="rfvtxtMarkObtained" runat="server" ControlToValidate="txtMarkObtained" ErrorMessage="*Mark Obtained" ForeColor="Red" ValidationGroup="gAdd" InitialValue=""></asp:RequiredFieldValidator>
                                                            <asp:CustomValidator ID="CustomValidator2" runat="server" ValidationGroup="gAdd" Display="Dynamic" ControlToValidate="txtMarkObtained" ForeColor="red" ErrorMessage="Marks Obtained Could not be greater than Max Marks!"
                                                                ClientValidationFunction="validateLength"></asp:CustomValidator>

                                                        </td>
                                                        <td>

                                                            <asp:TextBox ID="txtPercentageOfMarks" runat="server" Enabled="false" CssClass="form-control input-sm" MaxLength="5" placeholder="% Marks" Width="50px"></asp:TextBox>
                                                           <%-- <asp:FilteredTextBoxExtender ID="ftetxtPercentageOfMarks" runat="server" TargetControlID="txtPercentageOfMarks" FilterType="Numbers, Custom"></asp:FilteredTextBoxExtender>--%>

                                                        </td>
                                                        <td>

                                                            <asp:TextBox ID="txtGrade" runat="server" CssClass="form-contrinput-sm" MaxLength="1" placeholder="Grade" Width="50px"></asp:TextBox>
                                                            <asp:FilteredTextBoxExtender ID="ftetxtGrade" runat="server" TargetControlID="txtGrade" FilterType="LowercaseLetters, UppercaseLetters"></asp:FilteredTextBoxExtender>

                                                        </td>
                                                        <td>

                                                            <asp:TextBox ID="txtMediumOfInstruction" runat="server" CssClass="form-control input-sm" Width="100px" MaxLength="20" placeholder="Medium Of Instruction"></asp:TextBox>
                                                            <asp:RequiredFieldValidator ID="rfvtxtMediumOfInstruction" runat="server" ControlToValidate="txtMediumOfInstruction"
                                                                ErrorMessage="*Medium Of Instruction" ForeColor="Red" ValidationGroup="gAdd" InitialValue=""></asp:RequiredFieldValidator>

                                                        </td>
                                                        <td>

                                                            <asp:TextBox ID="txtDesciplineSubj" runat="server" CssClass="form-control input-sm" MaxLength="100" Width="200px" placeholder="Descipline/Subject"></asp:TextBox>
                                                            <asp:RequiredFieldValidator ID="rfvtxtDesciplineSubj" runat="server" ControlToValidate="txtDesciplineSubj" ErrorMessage="*Descipline/Subject" ForeColor="Red" ValidationGroup="gAdd" InitialValue=""></asp:RequiredFieldValidator>


                                                        </td>
                                                        <td>
                                                            <div class="col-lg2" style="padding-left: 0px;">
                                                                <%-- <asp:Button ID="btnAdd" runat="server"  CssClass="form-control input-sm" Text="ADD" ValidationGroup="gAdd" OnClick="btnAdd_Click"  />    --%>
                                                                <asp:LinkButton ID="btnAdd" type="button" class="btn btn-info" runat="server" ValidationGroup="gAdd" OnClick="btnAdd_Click" OnClientClick="return SAVE();">  
                             <span class="glyphicon glyphicon-plus-sign"></span> ADD </asp:LinkButton>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                    <tr>
                                                        <td colspan="12">
                                                            <asp:Label ID="lblerror" Style="line-height: 30px" ForeColor="Red" runat="server" Text=""></asp:Label>
                                                        </td>
                                                    </tr>

                                                    <tr>
                                                        <td colspan="12">
                                                            <asp:GridView ID="grdQualification" runat="server" Width="100%" DataKeyNames="Qualification" CssClass="table table-striped table-bordered table-hover" AutoGenerateColumns="False" EmptyDataText="There are no data records to display." AllowPaging="true" PageSize="10" OnSelectedIndexChanged="grdQualification_SelectedIndexChanged">
                                                                <Columns>
                                                                    <asp:BoundField DataField="QualificationDesc" HeaderText="Qualification" SortExpression="Qualification" HeaderStyle-CssClass="visible-lg" ItemStyle-CssClass="visible-lg" />
                                                                    <asp:BoundField DataField="Description" HeaderText="Description" SortExpression="Description" HeaderStyle-CssClass="visible-lg" ItemStyle-CssClass="visible-lg" />
                                                                    <asp:BoundField DataField="YearOfPassing" HeaderText="Year Of Passing" SortExpression="DOB" HeaderStyle-CssClass="visible-lg" ItemStyle-CssClass="visible-lg" />
                                                                    <asp:BoundField DataField="SchoolCollege" HeaderText="School/College" SortExpression="SchoolCollege" HeaderStyle-CssClass="visible-lg" ItemStyle-CssClass="visible-lg" />
                                                                    <asp:BoundField DataField="BoardUniversity" HeaderText="Board/University" SortExpression="BoardUniversity" HeaderStyle-CssClass="visible-lg" ItemStyle-CssClass="visible-lg" />
                                                                    <asp:BoundField DataField="MaximumMarks" HeaderText="Maximum Marks" SortExpression="EnquiryType" HeaderStyle-CssClass="visible-lg" ItemStyle-CssClass="visible-lg" />
                                                                    <asp:BoundField DataField="MarksObtained" HeaderText="Marks Obtained" SortExpression="FathersName" HeaderStyle-CssClass="visible-lg" ItemStyle-CssClass="visible-lg" />
                                                                    <asp:BoundField DataField="PMarks" HeaderText="%Marks" SortExpression="PMarks" HeaderStyle-CssClass="visible-lg" ItemStyle-CssClass="visible-lg" />
                                                                    <asp:BoundField DataField="Grade" HeaderText="Grade" SortExpression="Grade" HeaderStyle-CssClass="visible-lg" ItemStyle-CssClass="visible-lg" />
                                                                    <asp:BoundField DataField="MOI" HeaderText="Medium of Instruction" SortExpression="MOI" ItemStyle-CssClass="visible-lg" HeaderStyle-CssClass="visible-lg" />
                                                                    <asp:BoundField DataField="DesciplineSubj" HeaderText="Descipline/Subjext" SortExpression="DesciplineSubj" ItemStyle-CssClass="visible-lg" HeaderStyle-CssClass="visible-lg" />
                                                                    <asp:ButtonField CommandName="Select" Text="Delete" />
                                                                </Columns>
                                                                <AlternatingRowStyle CssClass="danger" />
                                                            </asp:GridView>
                                                        </td>
                                                    </tr>
                                                </table>
                                            </div>
                                        </asp:Panel>
                                    </div>
                                    <%--Qualification-------End---%>
                                    <div id="dvSave" runat="server" style="border-color: #ACE9FB; background-color: #ACE9FB; height: 50px" align="right">
                                        <asp:LinkButton ID="btnSave" type="button" class="btn btn-info" runat="server" OnClick="btnSave_Click" OnClientClick="return SAVE();">  
                             <span class="glyphicon glyphicon-save"></span> SUBMIT & PAY </asp:LinkButton>
                                    </div>
                                    <asp:HiddenField runat="server" ID="hfApplicationNo" />
                                    <asp:HiddenField ID="key" runat="server" />
                                    <asp:HiddenField ID="hash" runat="server" />
                                    <asp:HiddenField ID="txnid" runat="server" />
                                    <input type="hidden" runat="server" id="surl" name="surl" value="http://tmu.ac.in/feepay/surl.aspx" />
                                    <input type="hidden" runat="server" id="furl" name="furl" value="http://tmu.ac.in/feepay/furl.aspx" />
                                    <input type="hidden" runat="server" id="curl" name="curl" value="http://tmu.ac.in/feepay/curl.aspx" />
                                    <input type="hidden" runat="server" id="service_provider" name="service_provider" value="payu_paisa" />

                                </ContentTemplate>
                                <Triggers>
                                    <asp:AsyncPostBackTrigger ControlID="rblRegStep" EventName="SelectedIndexChanged" />
                                    <asp:PostBackTrigger ControlID="btnValidateOTP" />
                                    <%--<asp:PostBackTrigger ControlID="btnUpload"  />--%>
                                    <asp:PostBackTrigger ControlID="btnSave" />
                                </Triggers>
                            </asp:UpdatePanel>
                        </div>
                    </div>
                </div>

            </div>
        </div>

    </form>
    <script type="text/javascript">

        function sumCalc() {
            var _txt1 = document.getElementById('<%= txtMaximum.ClientID %>');
        var _txt2 = document.getElementById('<%= txtMarkObtained.ClientID %>');
        var _txt3 = document.getElementById('<%= txtPercentageOfMarks.ClientID %>');
        var t1 = 0, t2 = 0;

        if (_txt1.value != "") t1 = _txt1.value;
        if (_txt2.value != "") t2 = _txt2.value;

        _txt3.value = parseFloat(t2) * parseFloat(t1) / 100;
    }
    </script>
</body>
</html>
